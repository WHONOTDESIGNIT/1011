      { title: 'Retail Readiness', description: 'Packaging, labeling, and documentation aligned for retail channels' },
      { title: 'Quality Consistency', description: 'Defined QC checkpoints to reduce batch variation' },
      { title: 'Supply Reliability', description: 'Stable output planning with predictable lead times' },
