const data = caseStudies[slug];
if (!data) {
  return new Response('Not found', { status: 404 });
}

const heroStyle = data.heroBackgroundImage
  ? `background-image:url(${data.heroBackgroundImage});background-size:cover;background-position:center;background-blend-mode:overlay;`
  : '';
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.about'), path: '/about' },
  { label: t(locale, 'nav.clients'), path: '/clients' },
  { label: data.title },
]);
---

<BaseLayout title={data.title} lang={locale} description={data.subtitle}>
  <div class="space-y-48">
    <section class={`relative overflow-hidden rounded-2xl bg-gradient-to-r ${data.theme.heroGradient} px-8 py-14 text-white`} style={heroStyle}>
      <div class="pointer-events-none absolute inset-0 bg-black/30" />
      <div class="relative">
        <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />

        <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:items-center">
          <div>
            <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{data.title}</h1>
            <p class={`mt-5 max-w-3xl text-lg ${data.theme.heroTextAccent}`}>{data.subtitle}</p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a class="rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/contact')}>{data.cta.button}</a>
              <a class="rounded border border-white/30 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/clients')}>Back to clients</a>
            </div>
          </div>

          <div class="rounded-xl border border-white/20 bg-white/10 p-6 backdrop-blur-sm">
            <h2 class="text-xl font-semibold">Project Snapshot</h2>
            <dl class="mt-5 space-y-3 text-sm">
              {data.snapshot.map((row) => (
                <div class="flex items-start justify-between gap-4">
                  <dt class="text-white/80">{row.label}:</dt>
                  <dd class="text-right font-medium text-white">{row.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-center text-3xl font-bold text-slate-900">Key Results & Highlights</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {data.metrics.map((metric) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 text-center shadow-sm">
            <div class="text-lg font-semibold text-slate-900">{metric.title}</div>
            <div class="mt-2 text-sm text-slate-700">{metric.description}</div>
          </div>
        ))}
      </div>
    </section>

    <section class={`rounded-2xl ${data.theme.softBg} px-8 py-12`}>
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="text-3xl font-bold text-slate-900">The Challenge</h2>
          {data.challengeIntro && <p class="mt-4 text-slate-700">{data.challengeIntro}</p>}
          <ul class="mt-6 space-y-3 text-slate-700">
            {data.challengeBullets.map((item) => (
              <li class="flex items-start gap-3">
                <span class={`mt-2 h-2 w-2 flex-shrink-0 rounded-2xl ${data.theme.accentBg}`} />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
          {data.challengeAside.title && <div class="text-lg font-semibold text-slate-900">{data.challengeAside.title}</div>}
          <blockquote class="mt-4 text-slate-700">
            <div class="text-base leading-relaxed">"{data.challengeAside.quote}"</div>
            <div class="mt-4 text-sm font-medium text-slate-600">— {data.challengeAside.cite}</div>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-center text-3xl font-bold text-slate-900">What We Delivered</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {data.delivered.map((item) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="text-lg font-semibold text-slate-900">{item.title}</div>
            <div class="mt-2 text-sm text-slate-700">{item.description}</div>
            {item.bullets?.length && (
              <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-700">
                {item.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>

    <section class="space-y-10">
      <h2 class="text-center text-3xl font-bold text-slate-900">Our Approach</h2>
      <div class="grid gap-8 md:grid-cols-2">
        {data.approach.map((step, idx) => (
          <div class="flex items-start gap-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class={`flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-2xl text-sm font-bold text-white ${data.theme.accentBg}`}>
              {idx + 1}
            </div>
            <div>
              <div class="text-lg font-semibold text-slate-900">{step.title}</div>
              <div class="mt-2 text-sm text-slate-700">{step.description}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-center text-3xl font-bold text-slate-900">Technology & Capabilities</h2>
      <div class={`grid gap-6 ${data.technology.length === 3 ? 'md:grid-cols-3' : 'md:grid-cols-2'}`}>
        {data.technology.map((block) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="text-lg font-semibold text-slate-900">{block.title}</div>
            <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-700">
              {block.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class={`rounded-2xl ${data.theme.softBg} px-8 py-12`}>
      <h2 class="text-3xl font-bold text-slate-900">Results</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {data.results.map((r) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="text-lg font-semibold text-slate-900">{r.title}</div>
            <div class="mt-2 text-sm text-slate-700">{r.description}</div>
          </div>
        ))}
      </div>
    </section>

    <section class={`rounded-2xl ${data.theme.softBg} px-8 py-12`}>
      <h2 class="text-center text-3xl font-bold text-slate-900">Client Perspective</h2>
      <div class="mx-auto mt-8 max-w-4xl rounded-xl border border-slate-200 bg-white p-8 text-center shadow-sm">
        <blockquote class="text-lg italic leading-relaxed text-slate-700">"{data.testimonial.quote}"</blockquote>
        <div class="mt-6 text-sm font-medium text-slate-600">— {data.testimonial.cite}</div>
      </div>
    </section>

    <section class={`rounded-2xl bg-gradient-to-r ${data.theme.heroGradient} px-8 py-12 text-white`}>
      <h2 class="text-3xl font-bold">{data.cta.title}</h2>
      <p class={`mt-4 max-w-3xl text-lg ${data.theme.heroTextAccent}`}>{data.cta.description}</p>
      <div class="mt-8">
        <a class="inline-flex rounded bg-white px-5 py-3 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/contact')}>{data.cta.button}</a>
      </div>
    </section>
  </div>
</BaseLayout>

