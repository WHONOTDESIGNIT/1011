  'happyskinco-ipl': {
    title: "HappySkinCo × iShine: Building Australia's IPL Success Story",
    subtitle:
      "How we became HappySkinCo's exclusive IPL supplier, helping them maintain leadership in Australia's competitive beauty market and establish themselves as the industry benchmark.",
