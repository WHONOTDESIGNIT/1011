---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { t } from '../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../lib/breadcrumbs';



const locale = 'en'; const { slug } = Astro.params;

type Theme = {
  heroGradient: string;
  heroTextAccent: string;
  accentBg: string;
  accentText: string;
  softBg: string;
};

type Metric = { title: string; description: string };
type Step = { title: string; description: string };
type Card = { title: string; description: string; bullets?: string[] };
type Quote = { title?: string; quote: string; cite: string };

type CaseStudy = {
  title: string;
  subtitle: string;
  heroBackgroundImage?: string;
  snapshot: Array<{ label: string; value: string }>;
  metrics: Metric[];
  challengeIntro: string;
  challengeBullets: string[];
  challengeAside: Quote;
  delivered: Card[];
  approach: Step[];
  technology: Array<{ title: string; bullets: string[] }>;
  results: Metric[];
  testimonial: Quote;
  cta: { title: string; description: string; button: string };
  theme: Theme;
};

