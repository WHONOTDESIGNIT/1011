---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts } from '../lib/blog';
import CornerMarker from '../components/CornerMarker.astro';
import { Award, Package, FileText, Megaphone, ScanFace, Snowflake, Smartphone, Zap, SlidersHorizontal, Layers } from '@lucide/astro';
import { getLocalizedPath } from '../lib/breadcrumbs';

export const prerender = false;

const locale = 'en';

const pageTitle = 'iShine - Professional IPL Hair Removal Device Manufacturer';
const pageDescription = 'iShine is an OEM and ODM IPL hair removal device manufacturer providing custom design, compliant production, packaging, and global delivery for beauty brands and retailers.';

const quickFeatures = [
  { title: 'IPL Niche King', icon: Award, description: 'Custom wavelengths, skin sensors, FDA/CE docs.' },
  { title: 'Supply Chain Support', icon: Package, description: 'MOQ, lead time, quality control.' },
  { title: 'Private-label for You', icon: FileText, description: 'From idea to branded box in weeks, not months.' },
  { title: 'Meta Friendly', icon: Megaphone, description: 'Run high-converting Meta ads without policy violations. We\'ll help you craft compliant, compelling claims.' },
];

const whoWeAre = [
  'iShine Technology partners with global retailers and beauty leaders — including Costco, RoseSkinCo, and KU2 Cosmetics — to deliver innovative home-use IPL hair removal devices. We help brands expand into the fast-growing beauty-tech market with products that combine advanced technology, safety, and design excellence.',
  'As a full-service OEM and ODM manufacturer, we provide end-to-end solutions: from concept design and prototyping to large-scale production, custom packaging, and worldwide logistics.',
  'Our team collaborates closely with brand owners, product managers, sourcing specialists, and designers to ensure every project is delivered on time, on budget, and aligned with brand identity.',
  'With successful partnerships across North America, Europe, and the Middle East, iShine has earned the trust of leading companies by turning ideas into market-ready IPL devices that drive growth and customer loyalty.',
];

const productCards = [
  { name: 'Lumi 2', tagline: 'Smart Skin Sensor', href: getLocalizedPath(locale, '/products/lumi-2'), image: '/images/products/lumi-2/Lumi2_Gallery_Hero_1.webp', hoverImage: '/images/products/lumi-2/Lumi2_Gallery_Hero_2.webp' },
  { name: 'Lumi', tagline: 'Smart App Control', href: getLocalizedPath(locale, '/products/lumi'), image: '/images/products/lumi/lumi_ipl_device_2.jpg', hoverImage: '/images/products/lumi/lumi_ipl_device_1.jpg' },
  { name: 'Sapphire', tagline: 'Premium Ice Cooling', href: getLocalizedPath(locale, '/products/sapphire'), image: '/images/products/sapphire-ipl-white.webp', hoverImage: '/images/products/using-sapphire-ipl.webp' },
  { name: 'Eirene', tagline: 'Professional Grade', href: getLocalizedPath(locale, '/products/eirene'), image: '/images/products/eirene/eirene_ipl_device.jpg', hoverImage: '/images/products/eirene/eirene_ipl_device_black_white_gold.webp' },
  { name: 'Golden', tagline: 'Luxury Edition', href: getLocalizedPath(locale, '/products/wooden'), image: '/images/products/luxury/luxury-ipl-device-front-view.png.webp', hoverImage: '/images/products/luxury/luxury-ipl-device-white.webp' },
  { name: 'Hebe', tagline: 'AI Skin Sensor', href: getLocalizedPath(locale, '/products/hebe'), image: '/images/products/Hebe/Hebe-ipl-device-front-view.webp', hoverImage: '/images/products/Hebe/Hebe-ipl-device-front-view-1.webp' },
  { name: 'Themis', tagline: 'Dual Lamp System', href: getLocalizedPath(locale, '/products/themis'), image: '/images/products/themis/themis_handheld_ipl_hair_removal_front_view.webp', hoverImage: '/images/products/themis/themis_handheld_ipl_hair_removal_side_view.webp' },
];

const testimonials = [
  { company: 'Costco', person: 'Sarah Johnson', role: 'Procurement Manager', region: 'Canada', quote: "iShine's IPL devices have exceeded our expectations. The quality and reliability are outstanding, making them perfect for our retail customers.", logo: '/images/logos/costco-logo.svg' },
  { company: 'RoseSkinCo', person: 'Michael Chen', role: 'Product Director', region: 'USA', quote: 'Working with iShine has been transformative for our brand. Their sapphire cooling technology set us apart in the competitive beauty market.', logo: '/images/logos/roseskin-logo.svg' },
  { company: 'KU-2 Cosmetic', person: 'Anna Mueller', role: 'Brand Manager', region: 'Germany', quote: 'The dual-lamp system designed by iShine helped us achieve European market leadership. Their technical expertise is unmatched.', logo: '/images/logos/KU-2 logo.svg' },
];

const partners = [
  { name: 'Costco', logo: '/images/logos/costco-logo.svg' },
  { name: 'RoseSkinCo', logo: '/images/logos/roseskin-logo.svg' },
  { name: 'KU-2 Cosmetic', logo: '/images/logos/KU-2 logo.svg' },
  { name: 'Ophir', logo: '/images/logos/ophir-logo.jpg' },
];

const caseStudies = [
  { title: 'RoseSkin - IPL Case Study', description: 'Transforming beauty routines with premium sapphire cooling technology.', href: getLocalizedPath(locale, '/clients/roseskin-ipl'), size: 'md:col-span-2' },
  { title: 'Costco - IPL Case Study', description: 'Delivering retail excellence with smart app-controlled IPL devices.', href: getLocalizedPath(locale, '/clients/costco-canada-ipl') },
  { title: 'KU2 - IPL Case Study', description: 'European market success through innovative dual-lamp technology.', href: getLocalizedPath(locale, '/clients/ku2-ipl') },
  { title: 'HappySkinCo - IPL Case Study', description: 'Luxury aesthetics meeting advanced IPL performance standards.', href: getLocalizedPath(locale, '/clients/happyskinco-ipl'), size: 'md:col-span-2' },
];

const capabilityList = [
  'Custom molded IPL device design', 'Rapid prototyping services', 'Ice cooling technology integration',
  'Multi-function IPL development', 'Smart app-connected devices', 'Sapphire IPL customization',
  'Dual-lamp system design', 'Skin sensor technology', 'Logo printing and branding',
  'Complete packaging solutions', 'Global shipping and logistics', 'After-sales support',
];

const capabilityStats = [
  { value: '15+', label: 'Years Experience' },
  { value: '50+', label: 'Global Partners' },
  { value: '500K+', label: 'Devices Produced' },
  { value: 'FDA', label: 'Cleared Devices' },
];

const technologyCards = [
  { title: 'AI Skin Sensor Technology', icon: ScanFace },
  { title: 'Sapphire Ice Cooling', icon: Snowflake },
  { title: 'Smart App Control', icon: Smartphone },
  { title: 'Dual Lamp System', icon: Zap },
  { title: 'Multi-Function Capabilities', icon: SlidersHorizontal },
  { title: 'Multi-Head Design', icon: Layers },
].map(({ title, icon }) => ({
  title, icon,
  description: 'Cutting-edge modules that help brands differentiate on performance, comfort, and user experience.',
  href: getLocalizedPath(locale, '/components'),
}));

const qualityItems = [
  { title: 'FDA Cleared Devices', description: 'Full support for FDA clearance process and ongoing compliance.' },
  { title: 'CE Marking', description: 'European market compliance for seamless distribution.' },
  { title: 'ISO 13485 Certified', description: 'Medical device quality management system certification.' },
  { title: 'MDSAP Compliant', description: 'Medical Device Single Audit Program for multiple markets.' },
];

const qualityStats = ['MDSAP Certified', 'FDA Cleared Products', 'CE Certified', 'ISO 13485 Certified'];

const macroStats = [
  { value: '15+', label: 'Years in Business' },
  { value: '500K+', label: 'Devices Manufactured' },
  { value: '50+', label: 'Global Partners' },
  { value: '20+', label: 'Countries Served' },
];

const statHighlights = [
  { title: 'Major Retailers', description: 'Trusted by leading retail chains including Costco Canada for consistent quality and reliability.' },
  { title: 'Beauty Brands', description: 'Powering successful beauty tech brands across USA, Europe, and Middle East markets.' },
  { title: 'Global Startups', description: 'Supporting innovative startups from concept to market with flexible MOQ and expert guidance.' },
];

const fallbackBlogPosts = [
  {
    title: 'Smart IPL Devices: The App-Connected Revolution',
    excerpt: 'Discover how app connectivity is transforming the IPL user experience with personalized treatment plans and progress tracking.',
    category: 'TECHNOLOGY', href: getLocalizedPath(locale, '/blog'),
    image: '/images/blog/blog-12-smart-ipl-devices-the-app-connected-revolution.jpg',
    readTime: '6 min read', date: '',
  },
  {
    title: 'Latest Advances in IPL Research',
    excerpt: 'Explore cutting-edge IPL technologies including AI-powered skin detection and next-generation cooling systems.',
    category: 'INNOVATION', href: getLocalizedPath(locale, '/blog'),
    image: '/images/blog/blog-09-AI-Skin-Sensor-Next-generation-IPL-with-AI-powered-skin-detection.jpg',
    readTime: '5 min read', date: '',
  },
  {
    title: 'OEM vs ODM: Choosing the Right Manufacturing Model',
    excerpt: 'Understanding the difference between OEM and ODM services and choosing the best approach for your brand.',
    category: 'GUIDE', href: getLocalizedPath(locale, '/blog'),
    image: '/images/blog/blog-02-oem-vs-odm-choosing-the-right-manufacturing-model.jpg',
    readTime: '7 min read', date: '',
  },
];

const latestPosts = await getAllPosts(locale);
const blogPosts = latestPosts.length ? latestPosts.slice(0, 3) : fallbackBlogPosts;
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} showCornerMarkers={false}>
  <main>
    <section class="hero-section relative w-screen left-1/2 -translate-x-1/2 flex items-center justify-center overflow-hidden px-6 text-center text-white md:px-10 lg:px-12 -mt-[160px] pt-[160px]" style="aspect-ratio:3230/1428">
      <img
        src="/images/home/hero-section-sapphire-ipl-device-white-color.webp"
        alt=""
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0" style="background:linear-gradient(rgba(140,113,114,0.35),rgba(140,113,114,0.35))"></div>
      <div class="relative z-10 w-full max-w-5xl px-4 sm:px-6">
        <h1 class="text-xl font-bold tracking-tight md:text-3xl lg:text-4xl xl:text-6xl">
          Building High-Performing IPL Devices
        </h1>
        <p class="mx-auto mt-3 hidden max-w-sm text-xs leading-relaxed text-white md:mt-4 md:block md:max-w-lg md:text-sm lg:mt-5 lg:max-w-2xl lg:text-base xl:mt-6 xl:text-lg">
          Custom design and production for major chains, global retailers, and beauty brands. From idea to market, we help you build certified, premium, retail-ready IPL products.
        </p>
        <div class="mt-5 md:mt-6 lg:mt-8 xl:mt-10">
          <a class="inline-flex rounded-xl bg-white font-semibold text-slate-950 transition hover:bg-slate-100" style="padding:clamp(0.375rem,1.2vw,0.75rem) clamp(1rem,3vw,2rem);font-size:clamp(0.72rem,1.1vw,0.875rem);border-radius:clamp(0.5rem,0.8vw,0.75rem)" href={getLocalizedPath(locale, '/contact')}>
            Get a Free Quote
          </a>
        </div>
      </div>
    </section>

    <CornerMarker class="compact" />
    <section class="features-grid grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {quickFeatures.map((feature) => (
        <article class="feature-card rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="feature-icon flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white">
            <feature.icon size={22} strokeWidth={1.5} />
          </div>
          <h2 class="feature-title mt-5 text-xl font-semibold text-slate-900">{feature.title}</h2>
          <p class="feature-desc mt-3 text-sm leading-relaxed text-slate-700">{feature.description}</p>
        </article>
      ))}
    </section>

    <CornerMarker />

    <section class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="relative h-full bg-slate-100 min-h-[300px]">
          <img
            src="/images/home/home-about-ishine.webp"
            alt="Who We Are"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover scale-y-[1.0132]"
          />
        </div>
      </div>
      <div>
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Who We Are</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">A full-stack IPL manufacturing partner for global beauty brands</h2>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-slate-700">
          {whoWeAre.map((paragraph) => (<p>{paragraph}</p>))}
        </div>
        <div class="mt-8">
          <a class="rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={getLocalizedPath(locale, '/about')}>
            Learn About iShine
          </a>
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="space-y-8 relative w-screen left-1/2 -translate-x-1/2">
      <div class="relative flex items-center justify-center">
        <button id="prev-product" class="absolute left-6 z-10 flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:bg-slate-50 hover:shadow-md" aria-label="Previous product">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="mx-auto max-w-3xl text-center">
          <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Product Showcase</div>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Our IPL Product Range</h2>
          <p class="mt-4 text-lg text-slate-700">From premium sapphire cooling to smart app-controlled devices, explore our complete range of customizable IPL solutions.</p>
        </div>
        <button id="next-product" class="absolute right-6 z-10 flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:bg-slate-50 hover:shadow-md" aria-label="Next product">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>

      <div id="product-carousel-viewport" class="overflow-hidden">
        <div id="product-carousel-track" class="flex gap-6 transition-transform duration-300 ease-out">
          {productCards.map((product) => (
            <a class="product-card flex-shrink-0 rounded-xl border-2 border-black bg-white shadow-sm overflow-hidden group transition-all" href={product.href}>
              <div class="flex h-full flex-col">
                <div class="relative bg-slate-100" style="flex: 806 0 0%; min-height:0">
                  <img class="product-card-image h-full w-full object-cover transition-opacity duration-300" src={product.image} alt={product.name} loading="lazy" data-original-src={product.image} data-hover-src={product.hoverImage} />
                </div>
                <div class="flex flex-col justify-end p-3" style="flex: 194 0 0%">
                  <div>
                    <h3 class="text-xl font-semibold text-slate-900">{product.name}</h3>
                    <p class="mt-1 text-sm text-slate-700">{product.tagline}</p>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="relative w-screen left-1/2 -translate-x-1/2 flex items-center justify-center">
      <div class="relative overflow-hidden rounded-2xl flex items-end justify-start px-8 pb-8 md:px-10 md:pb-10 lg:px-12 lg:pb-12 w-full" style="min-height:400px;max-width:3661px;aspect-ratio:3872/1082">
        <img src="/images/home/ishine_full_stack_factory.jpg" alt="" loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
        <div class="relative z-10" style="transform:translateX(50%)">
          <a class="inline-flex rounded-xl bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 shadow-md" href={getLocalizedPath(locale, '/services')}>View B2B Custom Package</a>
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Testimonials</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Why Work with iShine?</h2>
        <p class="mt-4 text-slate-700">We are not ones to sing our own praises, so we let our clients do the talking.</p>
        <div class="mt-8 space-y-4">
          {testimonials.slice(1).map((item) => (
            <div class="rounded-2xl bg-slate-50 p-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <div class="text-lg font-semibold text-slate-900">{item.company}</div>
                  <div class="text-sm text-slate-500">{item.region}</div>
                </div>
                <img src={item.logo} alt={`${item.company} logo`} width="120" height="40" class="h-10 w-auto object-contain" loading="lazy" />
              </div>
              <p class="mt-4 text-sm leading-relaxed text-slate-700">"{item.quote}"</p>
              <div class="mt-4 text-sm font-medium text-slate-900">{item.person}, {item.role}</div>
            </div>
          ))}
        </div>
      </div>

      <article class="rounded-2xl bg-gradient-to-br from-violet-700 via-purple-700 to-slate-900 p-8 text-white shadow-xl">
        <div class="flex items-center justify-between gap-4">
          <div>
            <div class="text-sm uppercase tracking-[0.22em] text-violet-200">{testimonials[0].region}</div>
            <h3 class="mt-2 text-3xl font-bold">{testimonials[0].company}</h3>
          </div>
          <img src={testimonials[0].logo} alt={`${testimonials[0].company} logo`} width="140" height="48" class="h-12 w-auto rounded bg-white/90 p-2" loading="lazy" />
        </div>
        <blockquote class="mt-8 text-2xl font-medium leading-relaxed text-white/95">"{testimonials[0].quote}"</blockquote>
        <div class="mt-8 flex items-center justify-between gap-4 border-t border-white/15 pt-6">
          <div>
            <div class="font-semibold">{testimonials[0].person}</div>
            <div class="text-sm text-violet-200">{testimonials[0].role}</div>
          </div>
          <a class="rounded-2xl border border-white/20 px-4 py-2 text-sm font-medium text-white transition hover:bg-white/10" href={getLocalizedPath(locale, '/clients')}>See all case studies</a>
        </div>
      </article>
    </section>

    <CornerMarker />

    <section class="space-y-8">
      <div class="text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Partners</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Collaborating Brands and Partners</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        {partners.map((partner) => (
          <div class="flex min-h-[120px] items-center justify-center rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
            <img src={partner.logo} alt={`${partner.name} logo`} width="140" height="56" loading="lazy" class="max-h-14 w-auto object-contain" />
          </div>
        ))}
      </div>
    </section>

    <CornerMarker />

    <section class="space-y-8">
      <div class="max-w-3xl">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Our Work</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Case studies that prove the manufacturing model works</h2>
        <p class="mt-4 text-lg text-slate-700">We are a specialist IPL hair removal device manufacturer in Shenzhen, trusted by global retailers and beauty brands for speed, compliance, and execution.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {caseStudies.map((item) => (
          <a class={`group rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-lg ${item.size ?? ''}`.trim()} href={item.href}>
            <div class="inline-flex rounded-2xl bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">Case Study</div>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-900">{item.title}</h3>
            <p class="mt-3 max-w-2xl text-slate-700">{item.description}</p>
            <div class="mt-6 text-sm font-medium text-slate-900">View case study →</div>
          </a>
        ))}
      </div>
    </section>

    <CornerMarker />

    <section class="rounded-2xl bg-slate-950 px-8 py-12 text-white shadow-2xl md:px-10">
      <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div>
          <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-300">Capabilities</div>
          <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">Complete Manufacturing Capabilities</h2>
          <p class="mt-4 max-w-3xl text-lg text-slate-300">From initial concept to final delivery, we handle every aspect of IPL device production with precision and expertise.</p>
          <div class="mt-8 grid gap-3 md:grid-cols-2">
            {capabilityList.map((item) => (
              <div class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-slate-200">
                <span class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-2xl bg-sky-400" />
                <span>{item}</span>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <a class="inline-flex rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-slate-100" href={getLocalizedPath(locale, '/services')}>Learn More About Our Services</a>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          {capabilityStats.map((stat) => (
            <div class="rounded-[1.5rem] border border-white/10 bg-white/10 p-6 backdrop-blur">
              <div class="text-4xl font-bold text-white">{stat.value}</div>
              <div class="mt-2 text-sm text-slate-300">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="space-y-8">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Technologies</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Advanced IPL Technologies</h2>
        <p class="mt-4 text-lg text-slate-700">Cutting-edge features that set our IPL devices apart in the global market.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {technologyCards.map((item) => (
          <a class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg" href={item.href}>
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white">
              <item.icon size={22} strokeWidth={1.5} />
            </div>
            <h3 class="mt-5 text-xl font-semibold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">{item.description}</p>
          </a>
        ))}
      </div>
    </section>

    <CornerMarker />

    <section class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Quality</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Quality Assurance and Global Certifications</h2>
        <p class="mt-4 text-lg text-slate-700">Every device undergoes rigorous testing and quality control processes to meet the highest international standards.</p>
        <div class="mt-8 grid gap-4">
          {qualityItems.map((item) => (
            <div class="rounded-2xl bg-slate-50 p-5">
