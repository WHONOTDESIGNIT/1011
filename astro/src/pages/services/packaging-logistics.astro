---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../lib/breadcrumbs';

const locale = 'en';
);
}

const heroImage =
  'https://images.pexels.com/photos/4483610/pexels-photo-4483610.jpeg?auto=compress&cs=tinysrgb&w=1600';

