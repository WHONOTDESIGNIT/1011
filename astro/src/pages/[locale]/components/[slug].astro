---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { t } from '../../../lib/i18n';
import { buildBreadcrumbs } from '../../../lib/breadcrumbs';

export const prerender = false;

const { locale, slug } = Astro.params;
if (locale !== 'en') {
  return new Response('Not found', { status: 404 });
}

const namespaceBySlug: Record<string, string> = {
  'lamp-cartridges': 'componentsLamp',
  'optical-filters': 'componentsFilter',
  'cooling-system': 'componentsCooling',
  'power-supply': 'componentsPower',
};

const ns = namespaceBySlug[slug];
if (!ns) return new Response('Not found', { status: 404 });

const title = t(locale, `${ns}.header.title`);
const description = t(locale, `${ns}.header.description`);

const backgroundImage =
  'https://images.pexels.com/photos/3825517/pexels-photo-3825517.jpeg?auto=compress&cs=tinysrgb&w=1600';

const specsRows =
  ns === 'componentsCooling' || ns === 'componentsFilter' || ns === 'componentsLamp'
    ? Array.from({ length: 6 }, (_, i) => ({
        parameter: t(locale, `${ns}.specs.rows.${i}.parameter`),
        value: t(locale, `${ns}.specs.rows.${i}.value`),
        notes: t(locale, `${ns}.specs.rows.${i}.description`),
      }))
    : [];

const complianceItems =
  ns === 'componentsCooling' || ns === 'componentsFilter' || ns === 'componentsLamp'
    ? [
        t(locale, `${ns}.compliance.items.ce`),
        t(locale, `${ns}.compliance.items.iso13485`),
        t(locale, `${ns}.compliance.items.fda`),
        t(locale, `${ns}.compliance.items.iec60601`),
        t(locale, `${ns}.compliance.items.mdr`),
      ]
    : [];

const showIntro = ns !== 'componentsPower' || (t(locale, `${ns}.intro.title`) && t(locale, `${ns}.intro.paragraph`));
const currentBreadcrumbLabel =
  slug === 'cooling-system'
    ? t(locale, `${ns}.breadcrumb.cooling`)
    : slug === 'optical-filters'
      ? t(locale, `${ns}.breadcrumb.filter`)
      : slug === 'lamp-cartridges'
        ? t(locale, `${ns}.breadcrumb.lamp`)
        : title;
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.products'), path: '/products' },
  { label: t(locale, 'nav.iplComponentsCatalogue'), path: '/components' },
  { label: currentBreadcrumbLabel },
]);
---

<BaseLayout title={title} lang={locale}>
  <div class="space-y-48">
    <section class="relative overflow-hidden rounded-2xl bg-slate-900 px-8 py-14 text-white">
      <div class="pointer-events-none absolute inset-0 opacity-30" style={`background-image:url(${backgroundImage});background-size:cover;background-position:center;`} />
      <div class="pointer-events-none absolute inset-0 bg-black/40" />
      <div class="relative">
        <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />
        <h1 class="mt-4 text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-200">{description}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={`/${locale}/contact`}>
            {ns === 'componentsCooling'
              ? t(locale, `${ns}.cta.button`)
              : ns === 'componentsFilter'
                ? t(locale, `${ns}.cta.button`)
                : ns === 'componentsLamp'
                  ? t(locale, `${ns}.cta.button`)
                  : t(locale, 'componentsPower.cta.button')}
          </a>
          <a class="rounded border border-white/30 px-4 py-2 text-sm font-medium text-white" href={`/${locale}/components`}>Back to components</a>
        </div>
      </div>
    </section>

    {showIntro && (
      <section class="space-y-10">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.intro.title`)}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">{t(locale, `${ns}.intro.paragraph`)}</p>
        </div>

        {ns === 'componentsPower' && (
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9]">
              <img
                src="/images/components/ipl-device-diagram.jpg"
                alt={t(locale, 'componentsPower.diagram.alt')}
                loading="lazy"
                class="h-full w-full object-cover"
              />
            </div>
          </div>
        )}
      </section>
    )}

    {ns === 'componentsCooling' && (
      <div class="space-y-16">
        <section class="rounded-2xl bg-sky-50 px-8 py-12">
          <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
            <div>
              <h2 class="text-2xl font-bold text-slate-900">{t(locale, `${ns}.highlight.whyTitle`)}</h2>
              <p class="mt-4 text-slate-700">{t(locale, `${ns}.highlight.paragraph`)}</p>
              <ul class="mt-6 space-y-3 text-slate-700">
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.comfort`)}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.safety`)}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.performance`)}</span>
                </li>
              </ul>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <img src="/images/components/cooling-system-closeup.jpg" alt={t(locale, `${ns}.highlight.imageAlt`)} loading="lazy" class="h-full w-full object-cover" />
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.tech.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.tech.description`)}</p>
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {[
              { title: t(locale, `${ns}.tech.items.plates.title`), description: t(locale, `${ns}.tech.items.plates.description`) },
              { title: t(locale, `${ns}.tech.items.sapphire.title`), description: t(locale, `${ns}.tech.items.sapphire.description`) },
              { title: t(locale, `${ns}.tech.items.semiconductor.title`), description: t(locale, `${ns}.tech.items.semiconductor.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-6">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.specs.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.specs.description`)}</p>
          </div>
          <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.parameter`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.value`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.notes`)}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {specsRows.map((row, idx) => (
                  <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="px-4 py-3 font-medium text-slate-900">{row.parameter}</td>
                    <td class="px-4 py-3 text-slate-700">{row.value}</td>
                    <td class="px-4 py-3 text-slate-600">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="text-sm italic text-slate-600">{t(locale, `${ns}.specs.footnote`)}</div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.customization.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.customization.description`)}</p>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.customization.blocks.plates.title`), description: t(locale, `${ns}.customization.blocks.plates.description`) },
              { title: t(locale, `${ns}.customization.blocks.sapphire.title`), description: t(locale, `${ns}.customization.blocks.sapphire.description`) },
              { title: t(locale, `${ns}.customization.blocks.integration.title`), description: t(locale, `${ns}.customization.blocks.integration.description`) },
              { title: t(locale, `${ns}.customization.blocks.temperature.title`), description: t(locale, `${ns}.customization.blocks.temperature.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.applications.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.applications.description`)}</p>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {[
              { title: t(locale, `${ns}.applications.items.home.title`), description: t(locale, `${ns}.applications.items.home.description`) },
              { title: t(locale, `${ns}.applications.items.multi.title`), description: t(locale, `${ns}.applications.items.multi.description`) },
              { title: t(locale, `${ns}.applications.items.pro.title`), description: t(locale, `${ns}.applications.items.pro.description`) },
              { title: t(locale, `${ns}.applications.items.sensitive.title`), description: t(locale, `${ns}.applications.items.sensitive.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-8">
          <h2 class="text-2xl font-bold text-slate-900">{t(locale, `${ns}.compliance.title`)}</h2>
          <p class="mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.compliance.paragraph`)}</p>
          <ul class="mt-6 grid gap-3 md:grid-cols-2">
            {complianceItems.map((item) => (
              <li class="rounded-lg bg-slate-50 px-4 py-3 text-sm text-slate-700">{item}</li>
            ))}
          </ul>
        </section>

        <section class="space-y-6">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.visuals.title`)}</h2>
          <div class="grid gap-6 md:grid-cols-2">
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <img src="/images/components/cooling-plate-diagram.jpg" alt={t(locale, `${ns}.visuals.images.plate.alt`)} loading="lazy" class="h-full w-full object-cover" />
              </div>
              <div class="p-4 text-sm text-slate-700">
                <div class="font-semibold">{t(locale, `${ns}.visuals.images.plate.title`)}</div>
                <div class="mt-1 text-slate-600">{t(locale, `${ns}.visuals.images.plate.caption`)}</div>
              </div>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <img src="/images/components/ipl-cooling-integration.jpg" alt={t(locale, `${ns}.visuals.images.integration.alt`)} loading="lazy" class="h-full w-full object-cover" />
              </div>
              <div class="p-4 text-sm text-slate-700">
                <div class="font-semibold">{t(locale, `${ns}.visuals.images.integration.title`)}</div>
                <div class="mt-1 text-slate-600">{t(locale, `${ns}.visuals.images.integration.caption`)}</div>
              </div>
            </div>
          </div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.quality.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.quality.paragraph`)}</p>
          </div>
          <div class="mt-6 text-center text-sm text-slate-700">
            <div class="font-semibold">{t(locale, `${ns}.quality.intertek`)}</div>
            <div class="mt-1 text-slate-600">{t(locale, `${ns}.quality.intertekDesc`)}</div>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.quality.blocks.stability.title`), description: t(locale, `${ns}.quality.blocks.stability.description`) },
              { title: t(locale, `${ns}.quality.blocks.longterm.title`), description: t(locale, `${ns}.quality.blocks.longterm.description`) },
              { title: t(locale, `${ns}.quality.blocks.contact.title`), description: t(locale, `${ns}.quality.blocks.contact.description`) },
              { title: t(locale, `${ns}.quality.blocks.cycling.title`), description: t(locale, `${ns}.quality.blocks.cycling.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl bg-slate-900 px-8 py-12 text-white">
          <h2 class="text-2xl font-bold">{t(locale, `${ns}.cta.title`)}</h2>
          <p class="mt-3 max-w-3xl text-slate-200">{t(locale, `${ns}.cta.description`)}</p>
          <div class="mt-6">
            <a class="inline-flex rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={`/${locale}/contact`}>{t(locale, `${ns}.cta.button`)}</a>
          </div>
        </section>
      </div>
    )}

    {ns === 'componentsFilter' && (
      <div class="space-y-16">
        <section class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="inline-flex rounded-2xl bg-slate-100 px-3 py-1 text-xs text-slate-700">{t(locale, `${ns}.highlight.badge`)}</div>
            <h2 class="mt-4 text-2xl font-bold text-slate-900">{t(locale, `${ns}.highlight.whyTitle`)}</h2>
            <p class="mt-4 text-slate-700">{t(locale, `${ns}.highlight.paragraph`)}</p>
          </div>
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[4/3]">
              <img src="/images/components/optical-filter-closeup.jpg" alt={t(locale, `${ns}.highlight.imageAlt`)} loading="lazy" class="h-full w-full object-cover" />
            </div>
          </div>
        </section>

        <section class="space-y-8">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.features.title`)}</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {[
              { title: t(locale, `${ns}.features.safety.title`), description: t(locale, `${ns}.features.safety.description`) },
              { title: t(locale, `${ns}.features.precision.title`), description: t(locale, `${ns}.features.precision.description`) },
              { title: t(locale, `${ns}.features.performance.title`), description: t(locale, `${ns}.features.performance.description`) },
              { title: t(locale, `${ns}.features.durability.title`), description: t(locale, `${ns}.features.durability.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-6">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.specs.title`)}</h2>
          <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.parameter`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.value`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.notes`)}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {specsRows.map((row, idx) => (
                  <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="px-4 py-3 font-medium text-slate-900">{row.parameter}</td>
                    <td class="px-4 py-3 text-slate-700">{row.value}</td>
                    <td class="px-4 py-3 text-slate-600">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="text-sm italic text-slate-600">{t(locale, `${ns}.specs.footnote`)}</div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.types.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.types.description`)}</p>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-3">
            {[
              { title: t(locale, `${ns}.types.fixed.title`), description: t(locale, `${ns}.types.fixed.description`) },
              { title: t(locale, `${ns}.types.replaceable.title`), description: t(locale, `${ns}.types.replaceable.description`) },
              { title: t(locale, `${ns}.types.specialized.title`), description: t(locale, `${ns}.types.specialized.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-8">
          <h2 class="text-2xl font-bold text-slate-900">{t(locale, `${ns}.customization.title`)}</h2>
          <div class="mt-8 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.customization.blocks.wavelengths.title`), description: t(locale, `${ns}.customization.blocks.wavelengths.description`) },
              { title: t(locale, `${ns}.customization.blocks.shape.title`), description: t(locale, `${ns}.customization.blocks.shape.description`) },
              { title: t(locale, `${ns}.customization.blocks.material.title`), description: t(locale, `${ns}.customization.blocks.material.description`) },
              { title: t(locale, `${ns}.customization.blocks.branding.title`), description: t(locale, `${ns}.customization.blocks.branding.description`) },
            ].map((item) => (
              <div class="rounded-xl bg-slate-50 p-6">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.quality.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.quality.paragraph`)}</p>
          </div>
          <div class="mt-6 text-center text-sm text-slate-700">
            <div class="font-semibold">{t(locale, `${ns}.quality.intertek`)}</div>
            <div class="mt-1 text-slate-600">{t(locale, `${ns}.quality.intertekDesc`)}</div>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.quality.blocks.wavelength.title`), description: t(locale, `${ns}.quality.blocks.wavelength.description`) },
              { title: t(locale, `${ns}.quality.blocks.transmission.title`), description: t(locale, `${ns}.quality.blocks.transmission.description`) },
              { title: t(locale, `${ns}.quality.blocks.heat.title`), description: t(locale, `${ns}.quality.blocks.heat.description`) },
              { title: t(locale, `${ns}.quality.blocks.durability.title`), description: t(locale, `${ns}.quality.blocks.durability.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-8">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.applications.title`)}</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {[
              { title: t(locale, `${ns}.applications.items.hair.title`), description: t(locale, `${ns}.applications.items.hair.description`) },
              { title: t(locale, `${ns}.applications.items.skin.title`), description: t(locale, `${ns}.applications.items.skin.description`) },
              { title: t(locale, `${ns}.applications.items.acne.title`), description: t(locale, `${ns}.applications.items.acne.description`) },
              { title: t(locale, `${ns}.applications.items.pigmentation.title`), description: t(locale, `${ns}.applications.items.pigmentation.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
