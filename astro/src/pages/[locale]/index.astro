---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/blog';
import CornerMarker from '../../components/CornerMarker.astro';
import { Award, Package, FileText, Megaphone, ScanFace, Snowflake, Smartphone, Zap, SlidersHorizontal, Layers } from '@lucide/astro';

const { locale } = Astro.params;

if (locale !== 'en' && locale !== 'es') {
  return new Response('Not found', { status: 404 });
}

const isEn = locale === 'en';

const pageTitle = isEn ? 'iShine - Professional IPL Hair Removal Device Manufacturer' : 'iShine - Fabricante Profesional de Dispositivos de Depilación IPL';
const pageDescription = isEn
  ? 'iShine is an OEM and ODM IPL hair removal device manufacturer providing custom design, compliant production, packaging, and global delivery for beauty brands and retailers.'
  : 'iShine es un fabricante OEM y ODM de dispositivos de depilación IPL que ofrece diseño personalizado, producción certificada, empaque y entrega global para marcas de belleza y minoristas.';

const quickFeatures = isEn ? [
  { title: 'IPL Niche King', icon: Award, description: 'Custom wavelengths, skin sensors, FDA/CE docs.' },
  { title: 'Supply Chain Support', icon: Package, description: 'MOQ, lead time, quality control.' },
  { title: 'Private-label for You', icon: FileText, description: 'From idea to branded box in weeks, not months.' },
  { title: 'Meta Friendly', icon: Megaphone, description: 'Run high-converting Meta ads without policy violations. We\'ll help you craft compliant, compelling claims.' },
] : [
  { title: 'Rey del Nicho IPL', icon: Award, description: 'Longitudes de onda personalizadas, sensores de piel, documentos FDA/CE.' },
  { title: 'Soporte de Cadena', icon: Package, description: 'MOQ, tiempo de entrega, control de calidad.' },
  { title: 'Marca Privada', icon: FileText, description: 'De la idea a la caja con marca en semanas, no meses.' },
  { title: 'Meta Friendly', icon: Megaphone, description: 'Ejecuta anuncios de Meta de alta conversión sin violaciones de políticas.' },
];

const whoWeAre = isEn ? [
  'iShine Technology partners with global retailers and beauty leaders — including Costco, RoseSkinCo, and KU2 Cosmetics — to deliver innovative home-use IPL hair removal devices. We help brands expand into the fast-growing beauty-tech market with products that combine advanced technology, safety, and design excellence.',
  'As a full-service OEM and ODM manufacturer, we provide end-to-end solutions: from concept design and prototyping to large-scale production, custom packaging, and worldwide logistics.',
  'Our team collaborates closely with brand owners, product managers, sourcing specialists, and designers to ensure every project is delivered on time, on budget, and aligned with brand identity.',
  'With successful partnerships across North America, Europe, and the Middle East, iShine has earned the trust of leading companies by turning ideas into market-ready IPL devices that drive growth and customer loyalty.',
] : [
  'iShine Technology se asocia con minoristas globales y líderes de belleza — incluyendo Costco, RoseSkinCo y KU2 Cosmetics — para ofrecer dispositivos innovadores de depilación IPL para uso doméstico. Ayudamos a las marcas a expandirse en el mercado de belleza-tecnología de rápido crecimiento con productos que combinan tecnología avanzada, seguridad y excelencia en diseño.',
  'Como fabricante OEM y ODM de servicio completo, proporcionamos soluciones integrales: desde el diseño conceptual y prototipado hasta la producción a gran escala, empaque personalizado y logística mundial.',
  'Nuestro equipo colabora estrechamente con dueños de marca, gerentes de producto, especialistas en abastecimiento y diseñadores para garantizar que cada proyecto se entregue a tiempo, dentro del presupuesto y alineado con la identidad de la marca.',
  'Con alianzas exitosas en Norteamérica, Europa y Medio Oriente, iShine se ha ganado la confianza de empresas líderes convirtiendo ideas en dispositivos IPL listos para el mercado que impulsan el crecimiento y la lealtad del cliente.',
];

const productCards = [
  { name: 'Lumi 2', tagline: isEn ? 'Smart Skin Sensor' : 'Sensor de Piel Inteligente', href: `/${locale}/products/lumi-2`, image: '/images/products/lumi-2/Lumi2_Gallery_Hero_1.webp', hoverImage: '/images/products/lumi-2/Lumi2_Gallery_Hero_2.webp' },
  { name: 'Lumi', tagline: isEn ? 'Smart App Control' : 'Control por App', href: `/${locale}/products/lumi`, image: '/images/products/lumi/lumi_ipl_device_2.jpg', hoverImage: '/images/products/lumi/lumi_ipl_device_1.jpg' },
  { name: 'Sapphire', tagline: isEn ? 'Premium Ice Cooling' : 'Enfriamiento de Hielo Premium', href: `/${locale}/products/sapphire`, image: '/images/products/sapphire-ipl-white.webp', hoverImage: '/images/products/using-sapphire-ipl.webp' },
  { name: 'Eirene', tagline: isEn ? 'Professional Grade' : 'Grado Profesional', href: `/${locale}/products/eirene`, image: '/images/products/eirene/eirene_ipl_device.jpg', hoverImage: '/images/products/eirene/eirene_ipl_device_black_white_gold.webp' },
  { name: 'Golden', tagline: isEn ? 'Luxury Edition' : 'Edición de Lujo', href: `/${locale}/products/wooden`, image: '/images/products/luxury/luxury-ipl-device-front-view.png.webp', hoverImage: '/images/products/luxury/luxury-ipl-device-white.webp' },
  { name: 'Hebe', tagline: isEn ? 'AI Skin Sensor' : 'Sensor de Piel con IA', href: `/${locale}/products/hebe`, image: '/images/products/Hebe/Hebe-ipl-device-front-view.webp', hoverImage: '/images/products/Hebe/Hebe-ipl-device-front-view-1.webp' },
  { name: 'Themis', tagline: isEn ? 'Dual Lamp System' : 'Sistema de Lámpara Dual', href: `/${locale}/products/themis`, image: '/images/products/themis/themis_handheld_ipl_hair_removal_front_view.webp', hoverImage: '/images/products/themis/themis_handheld_ipl_hair_removal_side_view.webp' },
];

const testimonials = isEn ? [
  { company: 'Costco', person: 'Sarah Johnson', role: 'Procurement Manager', region: 'Canada', quote: "iShine's IPL devices have exceeded our expectations. The quality and reliability are outstanding, making them perfect for our retail customers.", logo: '/images/logos/costco-logo.svg' },
  { company: 'RoseSkinCo', person: 'Michael Chen', role: 'Product Director', region: 'USA', quote: 'Working with iShine has been transformative for our brand. Their sapphire cooling technology set us apart in the competitive beauty market.', logo: '/images/logos/roseskin-logo.svg' },
  { company: 'KU-2 Cosmetic', person: 'Anna Mueller', role: 'Brand Manager', region: 'Germany', quote: 'The dual-lamp system designed by iShine helped us achieve European market leadership. Their technical expertise is unmatched.', logo: '/images/logos/KU-2 logo.svg' },
] : [
  { company: 'Costco', person: 'Sarah Johnson', role: 'Gerente de Compras', region: 'Canadá', quote: 'Los dispositivos IPL de iShine han superado nuestras expectativas. La calidad y fiabilidad son excepcionales.', logo: '/images/logos/costco-logo.svg' },
  { company: 'RoseSkinCo', person: 'Michael Chen', role: 'Director de Producto', region: 'EE.UU.', quote: 'Trabajar con iShine ha sido transformador para nuestra marca. Su tecnología de enfriamiento de zafiro nos diferencia en el mercado.', logo: '/images/logos/roseskin-logo.svg' },
  { company: 'KU-2 Cosmetic', person: 'Anna Mueller', role: 'Gerente de Marca', region: 'Alemania', quote: 'El sistema de lámpara dual diseñado por iShine nos ayudó a lograr el liderazgo en el mercado europeo.', logo: '/images/logos/KU-2 logo.svg' },
];

const partners = [
  { name: 'Costco', logo: '/images/logos/costco-logo.svg' },
  { name: 'RoseSkinCo', logo: '/images/logos/roseskin-logo.svg' },
  { name: 'KU-2 Cosmetic', logo: '/images/logos/KU-2 logo.svg' },
  { name: 'Ophir', logo: '/images/logos/ophir-logo.jpg' },
];

const caseStudies = [
  { title: isEn ? 'RoseSkin - IPL Case Study' : 'RoseSkin - Caso de Estudio IPL', description: isEn ? 'Transforming beauty routines with premium sapphire cooling technology.' : 'Transformando rutinas de belleza con tecnología de enfriamiento de zafiro premium.', href: `/${locale}/clients/roseskin-ipl`, size: 'md:col-span-2' },
  { title: isEn ? 'Costco - IPL Case Study' : 'Costco - Caso de Estudio IPL', description: isEn ? 'Delivering retail excellence with smart app-controlled IPL devices.' : 'Excelencia minorista con dispositivos IPL controlados por app.', href: `/${locale}/clients/costco-canada-ipl` },
  { title: isEn ? 'KU2 - IPL Case Study' : 'KU2 - Caso de Estudio IPL', description: isEn ? 'European market success through innovative dual-lamp technology.' : 'Éxito en el mercado europeo con tecnología innovadora de lámpara dual.', href: `/${locale}/clients/ku2-ipl` },
  { title: isEn ? 'HappySkinCo - IPL Case Study' : 'HappySkinCo - Caso de Estudio IPL', description: isEn ? 'Luxury aesthetics meeting advanced IPL performance standards.' : 'Estética de lujo combinada con estándares avanzados de rendimiento IPL.', href: `/${locale}/clients/happyskinco-ipl`, size: 'md:col-span-2' },
];

const capabilityList = isEn ? [
  'Custom molded IPL device design', 'Rapid prototyping services', 'Ice cooling technology integration',
  'Multi-function IPL development', 'Smart app-connected devices', 'Sapphire IPL customization',
  'Dual-lamp system design', 'Skin sensor technology', 'Logo printing and branding',
  'Complete packaging solutions', 'Global shipping and logistics', 'After-sales support',
] : [
  'Diseño personalizado de dispositivos IPL moldeados', 'Servicios de prototipado rápido', 'Integración de tecnología de enfriamiento',
  'Desarrollo IPL multifunción', 'Dispositivos conectados por app', 'Personalización IPL con zafiro',
  'Diseño de sistema de lámpara dual', 'Tecnología de sensor de piel', 'Impresión de logotipos y marca',
  'Soluciones completas de empaque', 'Envío y logística global', 'Soporte postventa',
];

const capabilityStats = [
  { value: '15+', label: isEn ? 'Years Experience' : 'Años de Experiencia' },
  { value: '50+', label: isEn ? 'Global Partners' : 'Socios Globales' },
  { value: '500K+', label: isEn ? 'Devices Produced' : 'Dispositivos Producidos' },
  { value: 'FDA', label: isEn ? 'Cleared Devices' : 'Dispositivos Aprobados' },
];

const technologyCards = [
  { title: isEn ? 'AI Skin Sensor Technology' : 'Tecnología de Sensor de Piel con IA', icon: ScanFace },
  { title: isEn ? 'Sapphire Ice Cooling' : 'Enfriamiento de Hielo Zafiro', icon: Snowflake },
  { title: isEn ? 'Smart App Control' : 'Control Inteligente por App', icon: Smartphone },
  { title: isEn ? 'Dual Lamp System' : 'Sistema de Lámpara Dual', icon: Zap },
  { title: isEn ? 'Multi-Function Capabilities' : 'Capacidades Multifunción', icon: SlidersHorizontal },
  { title: isEn ? 'Multi-Head Design' : 'Diseño Multicableza', icon: Layers },
].map(({ title, icon }) => ({
  title,
  icon,
  description: isEn ? 'Cutting-edge modules that help brands differentiate on performance, comfort, and user experience.' : 'Módulos de vanguardia que ayudan a las marcas a diferenciarse en rendimiento, comodidad y experiencia de usuario.',
  href: `/${locale}/components`,
}));

const qualityItems = isEn ? [
  { title: 'FDA Cleared Devices', description: 'Full support for FDA clearance process and ongoing compliance.' },
  { title: 'CE Marking', description: 'European market compliance for seamless distribution.' },
  { title: 'ISO 13485 Certified', description: 'Medical device quality management system certification.' },
  { title: 'MDSAP Compliant', description: 'Medical Device Single Audit Program for multiple markets.' },
] : [
  { title: 'Dispositivos Aprobados por FDA', description: 'Soporte completo para el proceso de aprobación FDA y cumplimiento continuo.' },
  { title: 'Marcado CE', description: 'Cumplimiento del mercado europeo para distribución sin problemas.' },
  { title: 'Certificado ISO 13485', description: 'Certificación del sistema de gestión de calidad de dispositivos médicos.' },
  { title: 'Cumplimiento MDSAP', description: 'Programa de Auditoría Única de Dispositivos Médicos para múltiples mercados.' },
];

const qualityStats = isEn ? ['MDSAP Certified', 'FDA Cleared Products', 'CE Certified', 'ISO 13485 Certified'] : ['Certificado MDSAP', 'Productos Aprobados FDA', 'Certificado CE', 'Certificado ISO 13485'];

const macroStats = [
  { value: '15+', label: isEn ? 'Years in Business' : 'Años en el Negocio' },
  { value: '500K+', label: isEn ? 'Devices Manufactured' : 'Dispositivos Fabricados' },
  { value: '50+', label: isEn ? 'Global Partners' : 'Socios Globales' },
  { value: '20+', label: isEn ? 'Countries Served' : 'Países Atendidos' },
];

const statHighlights = isEn ? [
  { title: 'Major Retailers', description: 'Trusted by leading retail chains including Costco Canada for consistent quality and reliability.' },
  { title: 'Beauty Brands', description: 'Powering successful beauty tech brands across USA, Europe, and Middle East markets.' },
  { title: 'Global Startups', description: 'Supporting innovative startups from concept to market with flexible MOQ and expert guidance.' },
] : [
  { title: 'Grandes Minoristas', description: 'Confiado por cadenas minoristas líderes, incluyendo Costco Canadá, por calidad y fiabilidad constantes.' },
  { title: 'Marcas de Belleza', description: 'Impulsando marcas exitosas de tecnología de belleza en mercados de EE.UU., Europa y Medio Oriente.' },
  { title: 'Startups Globales', description: 'Apoyando startups innovadoras desde el concepto hasta el mercado con MOQ flexible y orientación experta.' },
];

const fallbackBlogPosts = isEn ? [
  {
    title: 'Smart IPL Devices: The App-Connected Revolution',
    excerpt: 'Discover how app connectivity is transforming the IPL user experience with personalized treatment plans and progress tracking.',
    category: 'TECHNOLOGY',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-12-smart-ipl-devices-the-app-connected-revolution.jpg',
    readTime: '6 min read',
    date: '',
  },
  {
    title: 'Latest Advances in IPL Research',
    excerpt: 'Explore cutting-edge IPL technologies including AI-powered skin detection and next-generation cooling systems.',
    category: 'INNOVATION',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-09-AI-Skin-Sensor-Next-generation-IPL-with-AI-powered-skin-detection.jpg',
    readTime: '5 min read',
    date: '',
  },
  {
    title: 'OEM vs ODM: Choosing the Right Manufacturing Model',
    excerpt: 'Understanding the difference between OEM and ODM services and choosing the best approach for your brand.',
    category: 'GUIDE',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-02-oem-vs-odm-choosing-the-right-manufacturing-model.jpg',
    readTime: '7 min read',
    date: '',
  },
] : [
  {
    title: 'Dispositivos IPL Inteligentes: La Revolución Conectada',
    excerpt: 'Descubre cómo la conectividad de aplicaciones está transformando la experiencia del usuario IPL con planes de tratamiento personalizados.',
    category: 'TECNOLOGÍA',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-12-smart-ipl-devices-the-app-connected-revolution.jpg',
    readTime: '6 min',
    date: '',
  },
  {
    title: 'Últimos Avances en Investigación IPL',
    excerpt: 'Explora tecnologías IPL de vanguardia, incluyendo detección de piel con IA y sistemas de enfriamiento de próxima generación.',
    category: 'INNOVACIÓN',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-09-AI-Skin-Sensor-Next-generation-IPL-with-AI-powered-skin-detection.jpg',
    readTime: '5 min',
    date: '',
  },
  {
    title: 'OEM vs ODM: Cómo Elegir el Modelo de Fabricación Correcto',
    excerpt: 'Comprende la diferencia entre servicios OEM y ODM y elige el mejor enfoque para tu marca.',
    category: 'GUÍA',
    href: `/${locale}/blog`,
    image: '/images/blog/blog-02-oem-vs-odm-choosing-the-right-manufacturing-model.jpg',
    readTime: '7 min',
    date: '',
  },
];

const latestPosts = await getAllPosts(locale);
const blogPosts = latestPosts.length ? latestPosts.slice(0, 3) : fallbackBlogPosts;
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} showCornerMarkers={false}>
  <main>
    <section class="hero-section relative w-screen left-1/2 -translate-x-1/2 flex items-center justify-center overflow-hidden px-6 text-center text-white md:px-10 lg:px-12 -mt-[160px] pt-[160px]" style="aspect-ratio:3230/1428">
      <img
        src="/images/home/hero-section-sapphire-ipl-device-white-color.webp"
        alt=""
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0" style="background:linear-gradient(rgba(140,113,114,0.35),rgba(140,113,114,0.35))"></div>
      <div class="relative z-10 w-full max-w-5xl px-4 sm:px-6">
        <h1 class="text-xl font-bold tracking-tight md:text-3xl lg:text-4xl xl:text-6xl">
          {isEn ? 'Building High-Performing IPL Devices' : 'Construyendo Dispositivos IPL de Alto Rendimiento'}
        </h1>
        <p class="mx-auto mt-3 hidden max-w-sm text-xs leading-relaxed text-white md:mt-4 md:block md:max-w-lg md:text-sm lg:mt-5 lg:max-w-2xl lg:text-base xl:mt-6 xl:text-lg">
          Custom design and production for major chains, global retailers, and beauty brands. From idea to market, we help you build certified, premium, retail-ready IPL products.
        </p>
        <div class="mt-5 md:mt-6 lg:mt-8 xl:mt-10">
          <a class="inline-flex rounded-xl bg-white font-semibold text-slate-950 transition hover:bg-slate-100" style="padding:clamp(0.375rem,1.2vw,0.75rem) clamp(1rem,3vw,2rem);font-size:clamp(0.72rem,1.1vw,0.875rem);border-radius:clamp(0.5rem,0.8vw,0.75rem)" href={`/${locale}/contact`}>
            {isEn ? 'Get a Free Quote' : 'Solicita un Presupuesto Gratuito'}
          </a>
        </div>
      </div>
    </section>

    <CornerMarker class="compact" />
    <section class="features-grid grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {quickFeatures.map((feature) => (
        <article class="feature-card rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="feature-icon flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white">
            <feature.icon size={22} strokeWidth={1.5} />
          </div>
          <h2 class="feature-title mt-5 text-xl font-semibold text-slate-900">{feature.title}</h2>
          <p class="feature-desc mt-3 text-sm leading-relaxed text-slate-700">{feature.description}</p>
        </article>
      ))}
    </section>

    <CornerMarker />

    <section class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="relative h-full bg-slate-100 min-h-[300px]">
          <img
            src="/images/home/home-about-ishine.webp"
            alt="Who We Are"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover scale-y-[1.0132]"
          />
        </div>
      </div>
      <div>
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">{isEn ? 'Who We Are' : 'Quiénes Somos'}</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          {isEn ? 'A full-stack IPL manufacturing partner for global beauty brands' : 'Un socio de fabricación IPL integral para marcas de belleza globales'}
        </h2>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-slate-700">
          {whoWeAre.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        <div class="mt-8">
          <a class="rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={`/${locale}/about`}>
            {isEn ? 'Learn About iShine' : 'Conoce a iShine'}
          </a>
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="space-y-8 relative w-screen left-1/2 -translate-x-1/2">
      <div class="relative flex items-center justify-center">
        <button id="prev-product" class="absolute left-6 z-10 flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:bg-slate-50 hover:shadow-md" aria-label="Previous product">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <div class="mx-auto max-w-3xl text-center">
          <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">{isEn ? 'Product Showcase' : 'Vitrina de Productos'}</div>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">{isEn ? 'Our IPL Product Range' : 'Nuestra Gama de Productos IPL'}</h2>
          <p class="mt-4 text-lg text-slate-700">
            {isEn ? 'From premium sapphire cooling to smart app-controlled devices, explore our complete range of customizable IPL solutions.' : 'Desde enfriamiento premium de zafiro hasta dispositivos inteligentes controlados por app, explora nuestra gama completa de soluciones IPL personalizables.'}
          </p>
        </div>
        <button id="next-product" class="absolute right-6 z-10 flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:bg-slate-50 hover:shadow-md" aria-label="Next product">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>

      <div id="product-carousel-viewport" class="overflow-hidden">
        <div id="product-carousel-track" class="flex gap-6 transition-transform duration-300 ease-out">
          {productCards.map((product) => (
            <a class="product-card flex-shrink-0 rounded-xl border-2 border-black bg-white shadow-sm overflow-hidden group transition-all" href={product.href}>
              <div class="flex h-full flex-col">
                <div class="relative bg-slate-100" style="flex: 806 0 0%; min-height:0">
                  <img
                    class="product-card-image h-full w-full object-cover transition-opacity duration-300"
                    src={product.image}
                    alt={product.name}
                    loading="lazy"
                    data-original-src={product.image}
                    data-hover-src={product.hoverImage}
                  />
                </div>
                <div class="flex flex-col justify-end p-3" style="flex: 194 0 0%">
                  <div>
                    <h3 class="text-xl font-semibold text-slate-900">{product.name}</h3>
                    <p class="mt-1 text-sm text-slate-700">{product.tagline}</p>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CornerMarker />

    <section class="relative w-screen left-1/2 -translate-x-1/2 flex items-center justify-center">
      <div class="relative overflow-hidden rounded-2xl flex items-end justify-start px-8 pb-8 md:px-10 md:pb-10 lg:px-12 lg:pb-12 w-full" style="min-height:400px;max-width:3661px;aspect-ratio:3872/1082">
      <img
        src="/images/home/ishine_full_stack_factory.jpg"
        alt=""
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="relative z-10" style="transform:translateX(50%)">
        <a class="inline-flex rounded-xl bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100 shadow-md" href={`/${locale}/services`}>
          View B2B Custom Package
        </a>
      </div>
    </div>
    </section>

    <CornerMarker />

    <section class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">{isEn ? 'Testimonials' : 'Testimonios'}</div>
