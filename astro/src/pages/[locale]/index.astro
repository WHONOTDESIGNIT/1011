<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('product-carousel-track');
    if (!track || track.children.length === 0) return;

    const cards = track.querySelectorAll('.product-card');
    const gap = 24;
    const totalCards = cards.length;
    let currentIndex = 0;

    function getCardWidth() {
      return cards[0]?.offsetWidth || 0;
    }

    function clampIndex(index) {
      return Math.max(0, Math.min(index, totalCards - 1));
    }

    function updateCarousel(animate = true) {
      const w = getCardWidth();
      if (w === 0) return;

      const step = w + gap;
      const translateX = step * currentIndex;

      track.style.transition = animate ? 'transform 300ms ease-out' : 'none';
      track.style.transform = `translateX(-${translateX}px)`;
    }

    function next() {
      if (currentIndex < totalCards - 1) {
        currentIndex++;
        updateCarousel(true);
      }
    }

    function prev() {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel(true);
      }
    }

    document.querySelectorAll('#prev-product').forEach(btn => btn.addEventListener('click', prev));
    document.querySelectorAll('#next-product').forEach(btn => btn.addEventListener('click', next));

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => updateCarousel(false), 100);
    });

    updateCarousel(false);

    // Product card image hover switching - show second product image
    document.querySelectorAll('.product-card').forEach(card => {
      const img = card.querySelector('.product-card-image');
      if (!img) return;

      const originalSrc = img.getAttribute('data-original-src');
      const hoverSrc = img.getAttribute('data-hover-src');

      card.addEventListener('mouseenter', () => {
        if (hoverSrc && hoverSrc !== originalSrc) {
          img.style.transition = 'opacity 0.2s ease';
          img.style.opacity = '0';
          setTimeout(() => {
            img.src = hoverSrc;
            img.style.opacity = '1';
          }, 200);
        }
      });

      card.addEventListener('mouseleave', () => {
        if (originalSrc && img.src !== originalSrc) {
          img.style.transition = 'opacity 0.2s ease';
          img.style.opacity = '0';
          setTimeout(() => {
            img.src = originalSrc;
            img.style.opacity = '1';
          }, 200);
        }
      });
    });

    // Preload hover images
    document.querySelectorAll('.product-card-image').forEach(img => {
      const hoverSrc = img.getAttribute('data-hover-src');
      if (hoverSrc) {
        const preload = new Image();
        preload.src = hoverSrc;
      }
    });
  });
</script>

