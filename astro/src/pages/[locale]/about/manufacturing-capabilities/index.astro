---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { t } from '../../../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../../../lib/breadcrumbs';

const { locale = 'en' } = Astro.params;
if (locale !== 'en') {
  return new Response('Not found', { status: 404 });
}

const heroBackgroundImage =
  'https://images.pexels.com/photos/3825517/pexels-photo-3825517.jpeg?auto=compress&cs=tinysrgb&w=1600';

const cards = [
  {
    title: 'Industry Excellence',
    accent: 'bg-sky-600',
    description: '15+ years of experience in IPL manufacturing with proven track record of success.',
  },
  {
    title: 'Advanced Technology',
    accent: 'bg-emerald-600',
    description: 'State-of-the-art facilities and cutting-edge manufacturing processes.',
  },
  {
    title: 'Quality Assurance',
    accent: 'bg-amber-500',
    description: 'Rigorous testing and quality control at every production stage.',
  },
  {
    title: 'Global Standards',
    accent: 'bg-violet-600',
    description: 'FDA cleared and CE certified products meeting international standards.',
  },
];

const reasons = [
  'Comprehensive end-to-end manufacturing solutions',
  'Flexible MOQ to support startups and established brands',
  'Fast prototyping and reliable production timelines',
  'Complete compliance and certification support',
  'Global shipping and logistics expertise',
];
const pageTitle = t(locale, 'nav.manufacturing');
const pageDescription = 'Explore iShine\'s advanced IPL manufacturing facilities: injection molding, precision assembly, clean rooms, rapid prototyping, and scalable production for global beauty brands.';
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.about'), path: '/about' },
  { label: pageTitle },
]);
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription}>
  <div class="space-y-48">
    <section class="relative overflow-hidden rounded-2xl bg-slate-900 px-8 py-14 text-white" style={`background-image:url(${heroBackgroundImage});background-size:cover;background-position:center;background-blend-mode:overlay;`}>
      <div class="pointer-events-none absolute inset-0 bg-black/40" />
      <div class="relative">
        <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />
        <h1 class="mt-6 text-4xl font-bold tracking-tight md:text-5xl">{pageTitle}</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-200">
          Explore our advanced manufacturing facilities and production capabilities
        </p>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="text-3xl font-bold text-slate-900">Our Facilities &amp; Equipment</h2>
      <p class="text-lg text-slate-700">
        Explore our advanced manufacturing facilities and production capabilities
      </p>
      <p class="text-lg text-slate-700">
        At iShine, we combine advanced technology with expert craftsmanship to deliver exceptional results. Our team works closely with clients throughout the entire process, ensuring every detail meets your specifications and exceeds market expectations.
      </p>
    </section>

    <section class="grid gap-8 md:grid-cols-2">
      {cards.map((card) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class={`mb-6 flex h-14 w-14 items-center justify-center rounded-2xl ${card.accent}`}>
            <span class="text-lg font-bold text-white">+</span>
          </div>
          <h3 class="text-xl font-semibold text-slate-900">{card.title}</h3>
          <p class="mt-3 text-slate-700">{card.description}</p>
        </div>
      ))}
    </section>

    <section class="rounded-2xl bg-slate-50 p-8">
      <h2 class="text-2xl font-bold text-slate-900">Why Choose iShine?</h2>
      <ul class="mt-6 space-y-3 text-slate-700">
        {reasons.map((r) => (
          <li class="flex items-start gap-3">
            <span class="mt-2 h-2 w-2 flex-shrink-0 rounded-2xl bg-emerald-600" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/contact')}>Request a Quote</a>
        <a class="rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/about')}>Back to About</a>
      </div>
    </section>
  </div>
</BaseLayout>
