
---
import { getCurrentLanguage } from "../utils/i18n.ts";
import { LANGUAGE_CONFIG } from "../config/i18n.ts";

const currentLang = getCurrentLanguage(Astro.url.pathname);
const currentConfig = LANGUAGE_CONFIG.find(l => l.code === currentLang);
---

<div class="inline-flex" id="lang-switcher">
  <button
    id="lang-btn"
    class="flex items-center gap-1.5 rounded-2xl border border-slate-200 bg-white px-3 py-1.5 text-sm text-slate-700 shadow-sm transition hover:border-sky-300 hover:text-sky-700"
  >
    <span class="flex items-center gap-1">
      <span class="text-base leading-none">{currentConfig?.flag}</span>
      <span class="hidden sm:inline">{currentConfig?.label}</span>
    </span>
    <svg class="h-3 w-3 text-white" id="lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
  </button>

  <div id="lang-dropdown" class="pointer-events-none fixed z-[9999] scale-95 rounded-2xl border border-slate-200 bg-white p-1.5 opacity-0 shadow-xl transition-all duration-200" style="display:none">
    {LANGUAGE_CONFIG.map((lang) => (
      <button
        class="flex w-full items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-slate-700 transition hover:bg-sky-50 hover:text-sky-700"
        data-lang={lang.code}
      >
        <span class="text-base leading-none">{lang.flag}</span>
        <span>{lang.label}</span>
      </button>
    ))}
  </div>
</div>

<script>
  const btn = document.getElementById('lang-btn');
  const dropdown = document.getElementById('lang-dropdown');
  const chevron = document.getElementById('lang-chevron');

  function positionDropdown() {
    if (!btn || !dropdown) return;
    const rect = btn.getBoundingClientRect();
    const spaceBelow = window.innerHeight - rect.bottom;
    const dropdownHeight = Math.min(44 * 20, 520);
    const top = spaceBelow >= dropdownHeight + 6
      ? rect.bottom + 6
      : rect.top - dropdownHeight - 6;
    dropdown.style.left = Math.min(rect.left, window.innerWidth - 200) + 'px';
    dropdown.style.top = top + 'px';
    dropdown.style.width = '176px';
  }

  function show() {
    if (!dropdown) return;
    positionDropdown();
    dropdown.style.display = 'block';
    requestAnimationFrame(() => {
      dropdown.classList.remove('pointer-events-none', 'opacity-0', 'scale-95');
      dropdown.classList.add('pointer-events-auto', 'opacity-100', 'scale-100');
    });
    if (chevron) chevron.classList.add('rotate-180');
  }

  function hide() {
    if (!dropdown) return;
    dropdown.classList.add('pointer-events-none', 'opacity-0', 'scale-95');
    dropdown.classList.remove('pointer-events-auto', 'opacity-100', 'scale-100');
    if (chevron) chevron.classList.remove('rotate-180');
    setTimeout(() => { dropdown.style.display = 'none'; }, 200);
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dropdown.classList.contains('opacity-100')) {
      hide();
    } else {
      show();
    }
  });

  document.addEventListener('click', () => hide());
  window.addEventListener('resize', () => {
    if (dropdown.classList.contains('opacity-100')) positionDropdown();
  });
  window.addEventListener('scroll', () => {
    if (dropdown.classList.contains('opacity-100')) positionDropdown();
  });

  const SUPPORTED = ["en", "ja", "es", "fr", "de", "he", "ru", "tr", "ar", "ko", "pt", "it", "nl", "th", "fa", "pl", "el", "ro", "id", "hi"];

  async function setLanguageAndRedirect(lang) {
    try {
      const response = await fetch("/get-location", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ language: lang }),
      });
      if (!response.ok) throw new Error("Failed to set language");

      const currentPath = window.location.pathname;
      const langRegex = new RegExp(`^/(${SUPPORTED.join("|")})(/|$)`);
      const match = currentPath.match(langRegex);

      let newPath;
      if (match) {
        newPath = currentPath.replace(langRegex, `/${lang}$2`);
      } else {
        newPath = `/${lang}${currentPath}`;
      }

      window.location.href = newPath;
    } catch (error) {
      console.error("Error changing language:", error);
    }
  }

  dropdown?.querySelectorAll('button[data-lang]').forEach((button) => {
    button.addEventListener('click', (e) => {
      e.stopPropagation();
      const lang = button.getAttribute('data-lang');
      if (lang) setLanguageAndRedirect(lang);
    });
  });
</script>
