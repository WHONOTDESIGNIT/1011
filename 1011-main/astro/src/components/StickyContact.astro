<div id="wechat-overlay" class="overlay hidden">
  <div class="overlay-backdrop"></div>
  <div class="overlay-content">
    <img src="/images/contacts/wechat_ishine_contact.jpeg" alt="WeChat QR Code" width="500" height="500" />
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('wechat-overlay');
    const wechatPart = document.querySelector('[data-type="wechat"]');

    function openWechat() {
      overlay.classList.remove('hidden');
      overlay.classList.add('visible');
    }

    function closeWechat() {
      overlay.classList.remove('visible');
      overlay.classList.add('hidden');
    }

    if (wechatPart) {
      wechatPart.addEventListener('click', openWechat);
    }

    if (overlay) {
      overlay.addEventListener('click', (e) => {
        if (!e.target.closest('.overlay-content')) {
          closeWechat();
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeWechat();
    });
  });
</script>

