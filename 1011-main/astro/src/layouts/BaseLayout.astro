const footerSections = [
  {
    title: t(lang, 'nav.products'),
    links: [
      { href: getLocalizedPath(lang, '/products'), label: t(lang, 'nav.products') },
      { href: getLocalizedPath(lang, '/products/lumi'), label: t(lang, 'nav.lumi') },
      { href: getLocalizedPath(lang, '/products/venus'), label: t(lang, 'nav.venus') },
      { href: getLocalizedPath(lang, '/products/wooden'), label: t(lang, 'nav.wooden') },
      { href: getLocalizedPath(lang, '/products/hebe'), label: t(lang, 'nav.hebe') },
      { href: getLocalizedPath(lang, '/products/alpha'), label: t(lang, 'nav.dualLamp') },
    ],
  },
  {
    title: t(lang, 'nav.iplComponentsCatalogue'),
    links: [
      { href: getLocalizedPath(lang, '/components'), label: t(lang, 'nav.iplComponentsCatalogue') },
      { href: getLocalizedPath(lang, '/components/lamp-cartridges'), label: t(lang, 'nav.lampCartridges') },
      { href: getLocalizedPath(lang, '/components/optical-filters'), label: t(lang, 'nav.opticalFilters') },
      { href: getLocalizedPath(lang, '/components/cooling-system'), label: t(lang, 'nav.coolingSystem') },
      { href: getLocalizedPath(lang, '/components/power-supply'), label: t(lang, 'nav.powerSupply') },
    ],
  },
  {
    title: t(lang, 'nav.serviceSupport'),
    links: [
      { href: getLocalizedPath(lang, '/services'), label: t(lang, 'nav.serviceSupport') },
      { href: getLocalizedPath(lang, '/services/oem-odm'), label: t(lang, 'nav.oemOdm') },
      { href: getLocalizedPath(lang, '/services/product-design'), label: t(lang, 'nav.productDesign') },
      { href: getLocalizedPath(lang, '/services/production-assembly'), label: t(lang, 'nav.production') },
      { href: getLocalizedPath(lang, '/services/packaging-logistics'), label: t(lang, 'nav.packaging') },
    ],
  },
  {
    title: t(lang, 'nav.about'),
    links: [
      { href: getLocalizedPath(lang, '/about'), label: t(lang, 'nav.about') },
      { href: getLocalizedPath(lang, '/about/brand-story'), label: t(lang, 'nav.brandStory') },
      { href: getLocalizedPath(lang, '/about/company-profile'), label: t(lang, 'nav.companyProfile') },
      { href: getLocalizedPath(lang, '/about/manufacturing-capabilities'), label: t(lang, 'nav.manufacturing') },
      { href: getLocalizedPath(lang, '/about/quality-control'), label: t(lang, 'nav.quality') },
      { href: getLocalizedPath(lang, '/clients'), label: t(lang, 'nav.clients') },
      { href: getLocalizedPath(lang, '/blog'), label: t(lang, 'nav.blog') },
      { href: getLocalizedPath(lang, '/faq'), label: t(lang, 'nav.faq') },
