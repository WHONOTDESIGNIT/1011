          </button>
        </div>
        <nav class="overflow-y-auto px-6 py-6">
          <ul class="space-y-1">
            {navItems.map((item) => (
              <li>
                {item.dropdown ? (
                  <div class="mobile-dropdown">
                    <button class="mobile-dropdown-trigger flex w-full items-center justify-between rounded-xl px-4 py-3 text-base font-medium text-slate-900 transition hover:bg-slate-50" data-mobile-dropdown-trigger>
                      {item.label}
                      <svg class="h-4 w-4 text-slate-400 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                    </button>
                    <div class="mobile-dropdown-panel hidden pl-4">
                      {item.dropdown.map((sub) => (
                        <a class="block rounded-xl px-4 py-2.5 text-sm text-slate-700 transition hover:bg-sky-50 hover:text-sky-700" href={sub.href}>{sub.label}</a>
                      ))}
                    </div>
                  </div>
                ) : (
                  <a class="block rounded-xl px-4 py-3 text-base font-medium text-slate-900 transition hover:bg-slate-50" href={item.href}>{item.label}</a>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Desktop dropdown JS (unchanged) -->
<script is:inline>
;(function initDropdowns() {
  const containers = document.querySelectorAll('[data-dropdown]')
  for (const container of containers) {
    const trigger = container.querySelector('[data-dropdown-trigger]')
    const panel = container.querySelector('[data-dropdown-panel]')
    if (!trigger || !panel) continue

    let hideTimer = null

    function show() {
      if (hideTimer) {
        clearTimeout(hideTimer)
        hideTimer = null
      }
      panel.classList.remove('pointer-events-none', 'opacity-0', 'scale-95')
      panel.classList.add('pointer-events-auto', 'opacity-100', 'scale-100')
      trigger.classList.add('text-sky-600')
      const chevron = trigger.querySelector('.dropdown-chevron')
      if (chevron) chevron.classList.add('opacity-100', 'rotate-180', 'text-sky-600')
    }

    function hide() {
      hideTimer = setTimeout(function () {
        panel.classList.add('pointer-events-none', 'opacity-0', 'scale-95')
        panel.classList.remove('pointer-events-auto', 'opacity-100', 'scale-100')
        trigger.classList.remove('text-sky-600')
        const chevron = trigger.querySelector('.dropdown-chevron')
        if (chevron) chevron.classList.remove('opacity-100', 'rotate-180', 'text-sky-600')
      }, 80)
    }

    container.addEventListener('mouseenter', function () {
      if (hideTimer) {
        clearTimeout(hideTimer)
        hideTimer = null
      }
      show()
    })
    container.addEventListener('mouseleave', hide)
    panel.addEventListener('mouseenter', function () {
      if (hideTimer) {
        clearTimeout(hideTimer)
        hideTimer = null
      }
    })
    panel.addEventListener('mouseleave', hide)
  }
})()
</script>

      <!-- Mobile menu + accordion JS -->
<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var btn = document.getElementById('mobile-menu-btn');
  var panel = document.getElementById('mobile-menu-panel');
  var close = document.getElementById('mobile-menu-close');
  if (!btn || !panel) return;

  function openMenu() {
    panel.classList.remove('hidden');
    panel.classList.add('flex', 'flex-col');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    panel.classList.add('hidden');
    panel.classList.remove('flex', 'flex-col');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', openMenu);
  if (close) close.addEventListener('click', closeMenu);
  panel.addEventListener('click', function(e) {
    if (e.target === panel) closeMenu();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });

  // Mobile accordion dropdowns
  panel.querySelectorAll('.mobile-dropdown-trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      var parent = trigger.closest('.mobile-dropdown');
      var content = parent.querySelector('.mobile-dropdown-panel');
      var chevron = trigger.querySelector('svg');
      if (!content) return;
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden');
      if (chevron) chevron.classList.toggle('rotate-180');
    });
  });
});
</script>

    </header>
    <div class="content-area mx-auto max-w-6xl px-6 pb-10">
    <slot />
