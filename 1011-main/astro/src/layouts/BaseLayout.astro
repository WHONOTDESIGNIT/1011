const footerUtilityLinks = [
  { href: getLocalizedPath(lang, '/contact'), label: 'Contact' },
  { href: getLocalizedPath(lang, '/faq'), label: 'FAQ' },
  { href: getLocalizedPath(lang, '/blog'), label: 'Blog' },
