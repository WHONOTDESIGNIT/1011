  { href: getLocalizedPath(lang, '/services'), label: t(lang, 'nav.serviceSupport'), dropdown: servicesLinks },
  { href: getLocalizedPath(lang, '/about'), label: t(lang, 'nav.about'), dropdown: aboutDropdownLinks },
  { href: getLocalizedPath(lang, '/contact'), label: t(lang, 'nav.contact') },
