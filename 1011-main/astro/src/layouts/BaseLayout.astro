---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || SITE_DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || SITE_DESCRIPTION} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd(lang))}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': 'https://iplmanufacturer.com/#website',
      url: 'https://iplmanufacturer.com',
      name: SITE_NAME,
      description: SITE_DESCRIPTION,
      inLanguage: lang,
      publisher: { '@id': 'https://iplmanufacturer.com/#organization' },
    })}></script>
    <meta property="og:image" content="/.netlify/images?url=/images/home/hero-section-sapphire-ipl-device-white-color.webp&w=1200&h=630&fit=cover&fm=png" />
    <meta name="twitter:image" content="/.netlify/images?url=/images/home/hero-section-sapphire-ipl-device-white-color.webp&w=1200&h=630&fit=cover&fm=png" />
    <link rel="icon" type="image/svg+xml" href="/images/logos/LOGO-SVG.svg" />
    <link rel="preconnect" href="https://images.pexels.com" />
    <link rel="preload" href="/fonts/Gilroy-Medium.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Gilroy-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Gilroy-Semibold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Gilroy-Extrabold.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <style is:inline set:html={criticalCss} />
    <link rel="stylesheet" href={globalCssUrl} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={globalCssUrl} /></noscript>
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <section class:list={['top-0 z-40 flex items-start bg-transparent', stickyNav ? 'sticky' : '']}>
      <div class="mx-auto flex w-full max-w-6xl items-center px-6" id="lang-bar-track">
        <div id="lang-bar-anchor">
          <LanguageSwitcher />
        </div>
      </div>
      <script is:inline>
      (function alignLangSwitcher() {
        function position() {
          var nav = document.querySelector('header nav');
          var anchor = document.getElementById('lang-bar-anchor');
          if (!nav || !anchor) return;
          var links = nav.querySelectorAll('a');
          var contact = links[links.length - 1];
          if (!contact) return;
          var contactRect = contact.getBoundingClientRect();
          var track = document.getElementById('lang-bar-track');
          if (!track) return;
          var trackRect = track.getBoundingClientRect();
          var offsetLeft = contactRect.right - trackRect.left + 4;
          anchor.style.marginLeft = Math.max(0, offsetLeft) + 'px';
        }
        position();
        window.addEventListener('resize', position);
        var observer = new MutationObserver(position);
        observer.observe(document.body, { childList: true, subtree: true, attributes: false });
        setTimeout(position, 300);
      })();
      </script>
    </section>
    <header class:list={['top-0 z-30 border-b border-transparent', stickyNav ? 'sticky' : '']}>
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
        <a class="logo-link flex items-center gap-3" href={getLocalizedPath(lang)} aria-label="iShine IPL Manufacturing – Home">
          <span class="flex items-center justify-center rounded-2xl bg-slate-900 font-bold text-white" style="width:clamp(1.75rem,3.2vw,2.5rem);height:clamp(1.75rem,3.2vw,2.5rem);font-size:clamp(0.65rem,1vw,0.875rem);border-radius:clamp(0.5rem,0.8vw,1rem)">IS</span>
          <span>
            <span class="block font-semibold uppercase tracking-[0.24em] text-sky-700" style="font-size:clamp(0.65rem,1vw,0.875rem)">iShine</span>
            <span class="block text-slate-500" style="font-size:clamp(0.6rem,0.85vw,0.875rem)">IPL Manufacturing</span>
          </span>
        </a>

        <!-- Desktop nav: lg (1024px) and above -->
        <div class="hidden lg:flex flex-1 items-center justify-end">
          <nav class="flex flex-wrap items-center justify-center gap-1 rounded-2xl border border-slate-200/60 bg-white/70 px-3 py-2 text-sm shadow-sm backdrop-blur-md">
            {navItems.map((item, index) =>
              item.dropdown ? (
                <div class="dropdown-container relative" data-dropdown>
                  <a class="dropdown-trigger flex cursor-pointer items-center gap-1.5 rounded-2xl px-3 py-1.5 text-slate-700 transition hover:text-sky-600" href={item.href} data-dropdown-trigger>
                    {item.label}
                    <svg class="dropdown-chevron h-3 w-3 text-slate-400 opacity-0 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                  </a>
                  <div class="dropdown-panel pointer-events-none absolute left-1/2 z-50 -translate-x-1/2 scale-95 rounded-2xl border border-slate-200 bg-white p-2 opacity-0 shadow-xl transition-all duration-200 before:pointer-events-none before:absolute before:-top-[6px] before:left-1/2 before:-ml-[6px] before:h-3 before:w-3 before:rotate-45 before:border-l before:border-t before:border-slate-200 before:bg-white" style="top:calc(100% + 8px)" data-dropdown-panel>
                    <div class="grid gap-0.5">
                      {item.dropdown.map((sub) => (
                        <a class="block rounded-xl px-3 py-2 text-sm text-slate-700 transition hover:bg-slate-50 hover:text-sky-600" href={sub.href}>{sub.label}</a>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <a class={`rounded-2xl px-3 py-1.5 transition hover:text-sky-600 ${index === 0 ? 'text-sky-600' : 'text-slate-700'}`} href={item.href}>
                  {item.label}
                </a>
              )
            )}
          </nav>
        </div>

        <!-- Hamburger button: below lg (<1024px) -->
        <button id="mobile-menu-btn" class="lg:hidden flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white shadow-sm transition hover:bg-slate-50" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <!-- Mobile menu overlay: below lg -->
      <div id="mobile-menu-panel" class="lg:hidden fixed inset-0 z-50 hidden bg-white">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
          <span class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-700">Menu</span>
