---
import { t } from '../lib/i18n';
import { getLocalizedPath } from '../lib/breadcrumbs';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import StickyContact from '../components/StickyContact.astro';
import CornerMarker from '../components/CornerMarker.astro';
import criticalCss from '../styles/critical.css?raw';
import globalCssUrl from '../styles/global.css?url';

const SITE_NAME = 'iShine - Professional IPL Hair Removal Device Manufacturer';
const SITE_DESCRIPTION = 'iShine is an OEM and ODM IPL hair removal device manufacturer providing custom design, compliant production, packaging, and global delivery for beauty brands and retailers.';

function organizationJsonLd(lang: string) {
  return {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://iplmanufacturer.com/#organization',
    name: 'iShine Technology Ltd',
    url: 'https://iplmanufacturer.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://iplmanufacturer.com/images/logos/ishine-logo.png',
      width: 600,
      height: 60,
    },
    description: SITE_DESCRIPTION,
    foundingDate: '2008',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Shenzhen',
      addressCountry: 'CN',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: '+86-150-1289-1148',
      contactType: 'sales',
      email: 'service@ishineco.com',
      availableLanguage: ['English', 'Chinese'],
    },
    areaServed: ['US', 'CA', 'DE', 'TR', 'AE', 'SA', 'GB', 'FR', 'ES', 'JP', 'KR'],
    sameAs: [
      'https://www.linkedin.com/company/ishine-technology',
      'https://www.youtube.com/@ishinetech',
      'https://www.facebook.com/ishinetech',
      'https://twitter.com/ishinetech',
      'https://www.instagram.com/ishinetech',
    ],
    knowsAbout: [
      'IPL hair removal device manufacturing',
      'OEM and ODM manufacturing services',
      'Sapphire cooling technology',
      'Beauty device design and production',
    ],
  };
}

type Props = {
  title: string;
  lang?: string;
  description?: string;
  canonical?: string;
  type?: 'website' | 'article';
  showCornerMarkers?: boolean;
  stickyNav?: boolean;
};

const { title, lang = 'en', description, canonical, type = 'website', showCornerMarkers = true, stickyNav = true } = Astro.props as Props;
const canonicalUrl = canonical || new URL(Astro.request.url).href;
const GOOGLE_SITE_VERIFICATION = 'Eyfk5Ty3dOOX_BJzvMRSlYcQZrToJVLY-J1yLRfPkA8';
const productLinks = [
  { href: getLocalizedPath(lang, '/products/lumi'), label: t(lang, 'nav.lumi') },
  { href: getLocalizedPath(lang, '/products/venus'), label: t(lang, 'nav.venus') },
  { href: getLocalizedPath(lang, '/products/eirene'), label: t(lang, 'nav.eirene') },
  { href: getLocalizedPath(lang, '/products/wooden'), label: t(lang, 'nav.wooden') },
  { href: getLocalizedPath(lang, '/products/hebe'), label: t(lang, 'nav.hebe') },
  { href: getLocalizedPath(lang, '/products/hestia'), label: t(lang, 'nav.hestia') },
  { href: getLocalizedPath(lang, '/products/euno'), label: t(lang, 'nav.euno') },
  { href: getLocalizedPath(lang, '/products/emerald'), label: t(lang, 'nav.emerald') },
  { href: getLocalizedPath(lang, '/products/themis'), label: t(lang, 'nav.themis') },
  { href: getLocalizedPath(lang, '/products/alpha'), label: t(lang, 'nav.alpha') },
];

const componentsLinks = [
  { href: getLocalizedPath(lang, '/components'), label: t(lang, 'nav.iplComponentsCatalogue') },
  { href: getLocalizedPath(lang, '/components/lamp-cartridges'), label: t(lang, 'nav.lampCartridges') },
  { href: getLocalizedPath(lang, '/components/optical-filters'), label: t(lang, 'nav.opticalFilters') },
  { href: getLocalizedPath(lang, '/components/cooling-system'), label: t(lang, 'nav.coolingSystem') },
  { href: getLocalizedPath(lang, '/components/power-supply'), label: t(lang, 'nav.powerSupply') },
];

const servicesLinks = [
  { href: getLocalizedPath(lang, '/services/oem-odm'), label: t(lang, 'nav.oemOdm') },
  { href: getLocalizedPath(lang, '/services/product-design'), label: t(lang, 'nav.productDesign') },
  { href: getLocalizedPath(lang, '/services/production-assembly'), label: t(lang, 'nav.production') },
  { href: getLocalizedPath(lang, '/services/packaging-logistics'), label: t(lang, 'nav.packaging') },
];

const aboutDropdownLinks = [
  { href: getLocalizedPath(lang, '/about/brand-story'), label: t(lang, 'nav.brandStory') },
  { href: getLocalizedPath(lang, '/about/company-profile'), label: t(lang, 'nav.companyProfile') },
  { href: getLocalizedPath(lang, '/about/manufacturing-capabilities'), label: t(lang, 'nav.manufacturing') },
  { href: getLocalizedPath(lang, '/about/quality-control'), label: t(lang, 'nav.quality') },
  { href: getLocalizedPath(lang, '/clients'), label: t(lang, 'nav.clients') },
  { href: getLocalizedPath(lang, '/blog'), label: t(lang, 'nav.blog') },
