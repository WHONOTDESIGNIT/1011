---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getPostBySlug, getRelatedPosts } from '../../lib/blog';
import { t } from '../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../lib/breadcrumbs';

const locale = 'en'; const { slug } = Astro.params;

const post = await getPostBySlug(locale, slug);
if (!post) {
  return new Response('Not found', { status: 404 });
}

function resolveBaseUrl() {
  return (process.env.URL ?? process.env.DEPLOY_PRIME_URL ?? process.env.SITE_URL ?? 'https://iplmanufacturer.com').replace(/\/$/, '');
}

const Content = post.Content as any;
const related = await getRelatedPosts(locale, post.meta.slug, post.meta.category, 3);
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.about'), path: '/about' },
  { label: t(locale, 'nav.blog'), path: '/blog' },
  { label: post.meta.title },
]);

const pageTitle = post.meta.title;
const pageDescription = post.meta.excerpt || t(locale, 'blog.meta.description');
const canonical = `${resolveBaseUrl()}${post.meta.href}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href ? `${resolveBaseUrl()}${item.href}` : canonical,
  })),
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  inLanguage: locale,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': canonical + '#article',
  headline: post.meta.title,
  description: pageDescription,
  url: canonical,
  datePublished: post.meta.date || undefined,
  dateModified: post.meta.date || undefined,
  author: {
    '@type': 'Person',
    name: post.meta.author || 'iShine Team',
    ...(post.meta.authorAvatar ? { image: post.meta.authorAvatar } : {}),
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://iplmanufacturer.com/#organization',
    name: 'iShine Technology Ltd',
  },
  ...(post.meta.image ? { image: post.meta.image } : {}),
  ...(post.meta.category ? { articleSection: post.meta.category } : {}),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  inLanguage: locale,
};
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} canonical={canonical} type="article" stickyNav={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="mx-auto max-w-5xl space-y-42">
    <header class="space-y-6">
      <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />

      <div class="space-y-2">
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-600">
          {post.meta.category
            ? <span class="rounded-2xl border border-slate-200 bg-white px-3 py-1 font-medium text-slate-700">{post.meta.category}</span>
            : null}
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950 md:text-5xl lg:text-6xl">{post.meta.title}</h1>
        {pageDescription
          ? <p class="max-w-3xl text-lg leading-relaxed text-slate-600">{pageDescription}</p>
          : null}
      </div>

      <div class="flex flex-wrap items-center gap-4 border-b border-slate-200 pb-6 text-sm text-slate-500">
        <div class="flex items-center gap-3">
          {post.meta.authorAvatar
            ? (
              <img
                src={post.meta.authorAvatar}
                alt={post.meta.author}
                class="h-10 w-10 rounded-2xl object-cover"
                loading="lazy"
              />
            )
            : (
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-100 text-sm font-semibold text-slate-500">
                {(post.meta.author || 'I').slice(0, 1)}
              </span>
            )}
          <div class="leading-tight">
            <span class="block text-xs uppercase tracking-[0.18em] text-slate-400">{t(locale, 'blog.post.authorLabel')}</span>
            <span class="block font-semibold text-slate-800">{post.meta.author}</span>
          </div>
        </div>
        {post.meta.date ? <time class="ml-auto">{post.meta.date}</time> : null}
      </div>
    </header>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What is this article about?</h3>
      <p class="mt-4 text-lg leading-relaxed text-slate-700">
        This article explains {post.meta.title} for teams evaluating or building private-label IPL hair removal products. It covers practical considerations for OEM/ODM execution, including how manufacturing choices can influence product experience, compliance planning, and launch readiness. The goal is to provide a self-contained overview that readers can reference when comparing options, preparing RFQs, or aligning internal stakeholders on requirements. Where relevant, the discussion connects component-level decisions (such as cooling, filters, lamp cartridges, sensors, and power design) with end-user comfort and repeatable production outcomes. The key takeaway is a clearer set of decision criteria you can use to reduce risk and move from concept to scalable manufacturing with fewer iterations.
      </p>
    </section>

    {post.meta.image
      ? (
        <figure class="-mx-4 overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm sm:mx-0">
          <div class="aspect-[16/9]">
            <img
              src={post.meta.image}
              alt={post.meta.title}
              loading="eager"
              class="h-full w-full object-cover"
            />
          </div>
        </figure>
      )
      : null}

    <div class="mx-auto max-w-3xl">
      <div class="blog-content">
        <Content />
      </div>

      <div class="mt-14 rounded-2xl bg-slate-950 px-8 py-10 text-white">
        <div class="mx-auto max-w-xl text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-300">{t(locale, 'blog.post.ctaTitle')}</p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight">{t(locale, 'blog.post.ctaHeading')}</h2>
          <p class="mt-4 text-sm leading-relaxed text-slate-300">{t(locale, 'blog.post.ctaDescription')}</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <a
              class="rounded-2xl bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100"
              href={getLocalizedPath(locale, '/contact')}
            >
              {t(locale, 'blog.post.ctaPrimary')}
            </a>
            <a
              class="rounded-2xl border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
              href={getLocalizedPath(locale, '/products')}
            >
              {t(locale, 'blog.post.ctaSecondary')}
            </a>
          </div>
        </div>
      </div>
    </div>

    {related.length
      ? (
        <section class="space-y-8">
          <div class="flex items-end justify-between gap-4 border-b border-slate-200 pb-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700">{t(locale, 'blog.post.relatedTitle')}</p>
              <h2 class="mt-1 text-2xl font-bold tracking-tight text-slate-900">{t(locale, 'blog.post.continueReadingTitle')}</h2>
            </div>
            <a
              class="hidden flex-shrink-0 rounded-2xl border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 md:inline-flex"
              href={getLocalizedPath(locale, '/blog#blog-archive')}
            >
              {t(locale, 'blog.post.viewAllArticles')}
            </a>
          </div>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {related.map((p) => (
              <a
                class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
                href={p.href}
              >
                {p.image
                  ? (
                    <div class="aspect-[16/10] overflow-hidden bg-slate-100">
                      <img
                        src={p.image}
                        alt={p.title}
                        loading="lazy"
                        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                      />
                    </div>
                  )
                  : (
                    <div class="flex aspect-[16/10] items-end bg-gradient-to-br from-slate-50 to-slate-100 p-6">
                      <span class="rounded-2xl bg-white/80 px-3 py-1 text-xs font-medium uppercase tracking-[0.18em] text-slate-400">
                        {t(locale, 'blog.common.noImage')}
                      </span>
                    </div>
                  )}
                <div class="space-y-3 p-5">
                  <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
                    {p.category
                      ? <span class="rounded-2xl bg-slate-100 px-2.5 py-0.5 font-medium text-slate-600">{p.category}</span>
                      : null}
                  </div>
                  <h3 class="text-lg font-semibold leading-snug tracking-tight text-slate-900">{p.title}</h3>
                  <p class="text-sm leading-relaxed text-slate-600">{p.excerpt}</p>
                  <span class="inline-flex items-center gap-1 text-sm font-medium text-sky-700 transition group-hover:gap-2">
                    {t(locale, 'blog.post.relatedCta')}
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
      : null}
  </article>
</BaseLayout>

<style is:global>
  .blog-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #1e293b;
  }
  .blog-content > :first-child {
    margin-top: 0;
  }
  .blog-content h1 {
    margin-top: 2.75rem;
    margin-bottom: 1.25rem;
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: #0f172a;
  }
  .blog-content h1:first-child {
    margin-top: 0;
  }
  .blog-content h2 {
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    font-size: 1.625rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: #0f172a;
  }
  .blog-content h2:first-child {
    margin-top: 0;
  }
  .blog-content h3 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.4;
    color: #0f172a;
  }
  .blog-content h3:first-child {
    margin-top: 0;
  }
  .blog-content h4 {
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    color: #0f172a;
  }
  .blog-content h4:first-child {
    margin-top: 0;
  }
  .blog-content p {
    margin-top: 1.25rem;
    margin-bottom: 0;
  }
  .blog-content p:first-child {
    margin-top: 0;
  }
  .blog-content a {
    color: #0f172a;
    text-decoration: underline;
    text-decoration-color: #cbd5e1;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  .blog-content a:hover {
    text-decoration-color: #6366f1;
  }
  .blog-content strong {
    font-weight: 600;
    color: #0f172a;
  }
  .blog-content ul,
  .blog-content ol {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .blog-content p + ul,
  .blog-content p + ol {
    margin-top: 0.75rem;
  }
  .blog-content li {
    margin-top: 0.5rem;
    margin-bottom: 0;
    line-height: 1.7;
  }
  .blog-content li > p {
    margin-top: 0.75rem;
  }
  .blog-content li > p:first-child {
    margin-top: 0;
  }
  .blog-content li::marker {
    color: #94a3b8;
  }
  .blog-content ul ul,
  .blog-content ol ol,
  .blog-content ul ol,
  .blog-content ol ul {
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
  }
  .blog-content blockquote {
    margin-top: 1.75rem;
    margin-bottom: 1.75rem;
    padding-left: 1.25rem;
    border-left: 3px solid #e2e8f0;
    font-style: italic;
    color: #475569;
  }
  .blog-content hr {
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
    border: 0;
    height: 1px;
    background: #e2e8f0;
  }
  .blog-content img {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 0.75rem;
    width: 100%;
    height: auto;
  }
  .blog-content figure {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .blog-content figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #64748b;
    text-align: center;
  }
  .blog-content table {
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    display: block;
    overflow-x: auto;
  }
  .blog-content th {
    padding: 0.625rem 0.75rem;
    text-align: left;
    font-weight: 600;
    color: #0f172a;
    border-bottom: 2px solid #e2e8f0;
  }
  .blog-content td {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid #f1f5f9;
    color: #334155;
  }
  .blog-content code {
    font-size: 0.875rem;
    padding: 0.125rem 0.375rem;
    background: #f1f5f9;
    border-radius: 0.25rem;
    color: #0f172a;
  }
  .blog-content pre {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding: 1rem;
    background: #0f172a;
    border-radius: 0.75rem;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #e2e8f0;
  }
  .blog-content pre code {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
</style>
