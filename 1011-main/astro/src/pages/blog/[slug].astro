---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getAllPosts, getPostBySlug, getRelatedPosts } from '../../lib/blog';
import { t } from '../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../lib/breadcrumbs';

const locale = 'en'; const { slug } = Astro.params;

const post = await getPostBySlug(locale, slug);
if (!post) {
  return new Response('Not found', { status: 404 });
}

function resolveBaseUrl() {
  return (process.env.URL ?? process.env.DEPLOY_PRIME_URL ?? process.env.SITE_URL ?? 'https://iplmanufacturer.com').replace(/\/$/, '');
}

const Content = post.Content as any;
const allPosts = await getAllPosts(locale);
const currentIndex = allPosts.findIndex((p) => p.slug === post.meta.slug);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost = currentIndex >= 0 && currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const related = await getRelatedPosts(locale, post.meta.slug, post.meta.category, 3);
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.about'), path: '/about' },
  { label: t(locale, 'nav.blog'), path: '/blog' },
  { label: post.meta.title },
]);

const pageTitle = post.meta.title;
const pageDescription = post.meta.excerpt || t(locale, 'blog.meta.description');
const canonical = `${resolveBaseUrl()}${post.meta.href}`;
const shareUrl = encodeURIComponent(canonical);
const shareTitle = encodeURIComponent(post.meta.title);
const facebookShareHref = `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`;
const xShareHref = `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}`;
const emailShareHref = `mailto:?subject=${shareTitle}&body=${shareUrl}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href ? `${resolveBaseUrl()}${item.href}` : canonical,
  })),
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: canonical,
  inLanguage: locale,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': canonical + '#article',
  headline: post.meta.title,
  description: pageDescription,
  url: canonical,
  datePublished: post.meta.date || undefined,
  dateModified: post.meta.date || undefined,
  author: {
    '@type': 'Person',
    name: post.meta.author || 'iShine Team',
    ...(post.meta.authorAvatar ? { image: post.meta.authorAvatar } : {}),
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://iplmanufacturer.com/#organization',
    name: 'iShine Technology Ltd',
  },
  ...(post.meta.image ? { image: post.meta.image } : {}),
  ...(post.meta.category ? { articleSection: post.meta.category } : {}),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  inLanguage: locale,
};
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} canonical={canonical} type="article" stickyNav={false}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <article class="blog-layout">
    <div class="container--narrow blog-breadcrumbs">
      <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />
    </div>

    <header class="container--narrow blog-article-header">
      <div class="article-tags">
        {post.meta.category ? <span class="article-tag">{post.meta.category}</span> : null}
      </div>
      <h1 class="article-title">{post.meta.title}</h1>
      {pageDescription ? <p class="article-subtitle">{pageDescription}</p> : null}
      <div class="article-meta">
        <div class="article-meta__author">
          {post.meta.authorAvatar ? (
            <img
              src={post.meta.authorAvatar}
              alt={post.meta.author}
              class="article-meta__avatar"
              loading="lazy"
              width="56"
              height="56"
            />
          ) : (
            <span class="article-meta__avatar article-meta__avatar--fallback">
              {(post.meta.author || 'I').slice(0, 1)}
            </span>
          )}
          <div class="article-meta__byline">
            <span class="article-meta__label">{t(locale, 'blog.post.authorLabel')}</span>
            <span class="article-meta__name">{post.meta.author}</span>
          </div>
        </div>
        <div class="article-meta__details">
          {post.meta.readTime ? <span>{post.meta.readTime}</span> : null}
          {post.meta.date ? <time>{post.meta.date}</time> : null}
        </div>
      </div>
    </header>

    <section class="container--narrow">
      {post.meta.image ? (
        <figure class="article-hero">
          <div class="article-hero__media">
            <img
              src={post.meta.image}
              alt={post.meta.title}
              loading="eager"
              class="article-hero__img"
            />
          </div>
        </figure>
      ) : null}

      <div class="blog-content">
        <Content />
      </div>
    </section>

    {related.length ? (
      <section class="container--medium blog-related">
        <div class="blog-section-header">
          <h2 class="blog-section-title">Recent Posts</h2>
        </div>
        <div class="related-grid">
          {related.map((p) => (
            <a class="article-card-mini" href={p.href}>
              <div class="article-card-mini__image-wrapper">
                {p.image ? (
                  <img class="article-card-mini__image" src={p.image} alt={p.title} loading="lazy" />
                ) : (
                  <div class="article-card-mini__image-placeholder">{t(locale, 'blog.common.noImage')}</div>
                )}
              </div>
              <div class="article-card-mini__body">
                <h3 class="article-card-mini__title">{p.title}</h3>
                <p class="article-card-mini__excerpt">{p.excerpt}</p>
                {p.date ? <time class="article-card-mini__date">{p.date}</time> : null}
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : null}

    <section class="container--medium blog-author">
      <div class="author-bio-card">
        <div class="author-bio-card__left">
          {post.meta.authorAvatar ? (
            <img
              src={post.meta.authorAvatar}
              alt={post.meta.author}
              class="author-bio-card__image"
              loading="lazy"
              width="120"
              height="120"
            />
          ) : (
            <div class="author-bio-card__image author-bio-card__image--fallback">{(post.meta.author || 'I').slice(0, 1)}</div>
          )}
        </div>
        <div class="author-bio-card__content">
          <div class="author-bio-card__name">{post.meta.author}</div>
          <div class="author-bio-card__role">Contributor</div>
          <p class="author-bio-card__bio">
            iShine publishes practical guidance for brands and sourcing teams building private-label IPL hair removal products, focused on OEM/ODM execution, component decisions, and launch readiness.
          </p>
        </div>
      </div>
    </section>

    <section class="container--narrow blog-share">
      <div class="blog-section-header">
        <h2 class="blog-section-title">Share this article</h2>
      </div>
      <div class="share-buttons">
        <a class="share-buttons__link" href={facebookShareHref} target="_blank" rel="noreferrer">Facebook</a>
        <a class="share-buttons__link" href={xShareHref} target="_blank" rel="noreferrer">X</a>
        <a class="share-buttons__link" href={emailShareHref}>Email</a>
      </div>
    </section>

    <nav class="container--narrow blog-article-nav" aria-label="Article navigation">
      <div class="article-nav__inner">
        {olderPost ? (
          <a class="article-nav__back" href={olderPost.href} aria-label="Previous article">
            ← Previous
          </a>
        ) : (
          <span></span>
        )}
        <a class="article-nav__all" href={getLocalizedPath(locale, '/blog#blog-archive')}>
          All Articles
        </a>
        {newerPost ? (
          <a class="article-nav__next" href={newerPost.href} aria-label="Next article">
            Next →
          </a>
        ) : (
          <span></span>
        )}
      </div>
    </nav>

    <section class="container--narrow blog-comments">
      <div class="blog-section-header">
        <h2 class="blog-section-title">Leave a comment</h2>
      </div>
      <form
        name="blog-comment"
        method="POST"
        action="/__forms/"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        class="comment-form"
      >
        <input type="hidden" name="form-name" value="blog-comment" />
        <input type="hidden" name="slug" value={post.meta.slug} />
        <input type="hidden" name="url" value={canonical} />
        <p class="comment-form__honeypot">
          <label>
            Do not fill this field:
            <input name="bot-field" />
          </label>
        </p>
        <div class="comment-form__row">
          <label class="comment-form__field">
            <span>Name</span>
            <input type="text" name="name" required />
          </label>
          <label class="comment-form__field">
            <span>Email</span>
            <input type="email" name="email" required />
          </label>
        </div>
        <label class="comment-form__field">
          <span>Message</span>
          <textarea name="message" rows="6" required></textarea>
        </label>
        <button class="comment-form__submit" type="submit">Post Comment</button>
      </form>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .blog-layout {
    padding: 3rem 0 5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .container--narrow {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }

  .container--medium {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }

  .blog-breadcrumbs {
    padding-bottom: 0.25rem;
  }

  .blog-article-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .article-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--blog-author-role-bg-color, #f3f4f6);
    color: var(--blog-author-role-text-color, #6b7280);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-title {
    font-size: 42px;
    line-height: 1.12;
    letter-spacing: -0.03em;
    font-weight: 800;
    color: var(--color-black, #000000);
    margin: 0;
  }

  .article-subtitle {
    margin: 0;
    font-size: 18px;
    line-height: 1.7;
    color: var(--lighter-text-color, #7B7B7B);
    max-width: 60ch;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--border-color, #E5E5E5);
    padding-bottom: 18px;
    margin-top: 8px;
  }

  .article-meta__author {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .article-meta__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    border: 4px solid var(--color-white, #FFFFFF);
    background: var(--blog-author-role-bg-color, #f3f4f6);
  }

  .article-meta__avatar--fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 18px;
    color: var(--blog-author-name-color, #111827);
  }

  .article-meta__byline {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }

  .article-meta__label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blog-nav-link-color, #9ca3af);
  }

  .article-meta__name {
    font-size: 16px;
    font-weight: 700;
    color: var(--blog-author-name-color, #111827);
  }

  .article-meta__details {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--lighter-text-color, #7B7B7B);
    font-size: 14px;
    font-weight: 600;
  }

  .article-hero {
    margin: 0 auto 2.5rem;
    max-width: 760px;
  }

  .article-hero__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 18px;
    background: var(--blog-author-role-bg-color, #f3f4f6);
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 10px 28px rgba(0,0,0,0.06);
  }

  .article-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-content img {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .blog-section-header {
    border-top: 1px solid var(--divider-color, #eeeeee);
    padding-top: 22px;
    margin-bottom: 18px;
  }

  .blog-section-title {
    margin: 0;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-black, #000000);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .article-card-mini {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
  }

  .article-card-mini__image-wrapper {
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    background: var(--blog-author-role-bg-color, #f3f4f6);
    border: 1px solid rgba(0,0,0,0.08);
  }

  .article-card-mini__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .article-card-mini:hover .article-card-mini__image {
    opacity: 0.8;
    transform: scale(1.05);
  }

  .article-card-mini__image-placeholder {
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 12px;
    color: var(--blog-nav-link-color, #9ca3af);
  }

  .article-card-mini__body {
    display: grid;
    gap: 8px;
  }

  .article-card-mini__title {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    min-height: calc(1.1rem * 1.4 * 3);
    color: var(--color-black, #000000);
    margin: 0;
  }

  .article-card-mini__excerpt {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--blog-author-body-color, #374151);
    margin: 0;
  }

  .article-card-mini__date {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blog-nav-link-color, #9ca3af);
  }

  .author-bio-card {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    padding: 24px;
    background: var(--color-white, #FFFFFF);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    position: relative;
    overflow: hidden;
  }

  .author-bio-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 6px;
    height: 100%;
    background: linear-gradient(180deg, var(--blog-author-name-color, #111827) 0%, var(--blog-author-body-color, #374151) 100%);
  }

  .author-bio-card__left {
    padding-left: 8px;
  }

  .author-bio-card__image {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid var(--color-white, #FFFFFF);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    object-fit: cover;
    display: block;
    background: var(--blog-author-role-bg-color, #f3f4f6);
    color: var(--blog-author-name-color, #111827);
  }

  .author-bio-card__image--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 38px;
  }

  .author-bio-card__content {
    display: grid;
    gap: 10px;
    padding-left: 12px;
  }

  .author-bio-card__name {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--blog-author-name-color, #111827);
  }

  .author-bio-card__role {
    display: inline-flex;
    width: fit-content;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blog-author-role-text-color, #6b7280);
    background: var(--blog-author-role-bg-color, #f3f4f6);
    border-radius: 999px;
    padding: 6px 10px;
  }

  .author-bio-card__bio {
    margin: 0;
    font-size: 15px;
    line-height: 1.7;
    color: var(--blog-author-body-color, #374151);
  }

  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .share-buttons__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--blog-share-bg-color, #f7f7f7);
    color: var(--blog-share-icon-color, #5c5c5c);
    text-decoration: none;
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: transform 180ms ease, background 180ms ease, color 180ms ease;
  }

  .share-buttons__link:hover {
    background: var(--blog-nav-hover-color, #0f172a);
    color: var(--color-white, #FFFFFF);
    transform: translateY(-2px);
  }

  .article-nav__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 32px;
    border-top: 1px solid var(--divider-color, #eeeeee);
    padding-top: 22px;
  }

  .article-nav__back,
  .article-nav__next {
    min-width: 190px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--blog-all-articles-border-color, #e5e7eb);
    border-radius: 999px;
    background: var(--color-white, #FFFFFF);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blog-all-articles-text-color, #334155);
    text-decoration: none;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .article-nav__back:hover,
  .article-nav__next:hover {
    background: var(--blog-nav-hover-color, #0f172a);
    border-color: var(--blog-nav-hover-color, #0f172a);
    color: var(--color-white, #FFFFFF);
  }

  .article-nav__next {
    justify-self: end;
  }

  .article-nav__all {
    min-width: 190px;
    height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--blog-all-articles-border-color, #e5e7eb);
    border-radius: 999px;
    background: var(--color-white, #FFFFFF);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blog-all-articles-text-color, #334155);
    text-decoration: none;
    transition: background 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .article-nav__all:hover {
    background: var(--blog-nav-hover-color, #0f172a);
    border-color: var(--blog-nav-hover-color, #0f172a);
    color: var(--color-white, #FFFFFF);
  }

  .comment-form {
    display: grid;
    gap: 16px;
    padding: 24px;
    background: var(--color-white, #FFFFFF);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }

  .comment-form__honeypot {
    display: none;
  }

  .comment-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .comment-form__field {
    display: grid;
    gap: 8px;
    font-weight: 700;
    color: var(--blog-author-name-color, #111827);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .comment-form__field input,
  .comment-form__field textarea {
    width: 100%;
    border: 1px solid var(--border-color, #E5E5E5);
    border-radius: 18px;
    padding: 12px 14px;
    font-size: 15px;
    color: var(--text-color, #333333);
    background: var(--section-bg, #F9FAFB);
    outline: none;
  }

  .comment-form__field input:focus,
  .comment-form__field textarea:focus {
    border-color: var(--primary-color, #F58C28);
    background: var(--color-white, #FFFFFF);
  }

  .comment-form__submit {
    height: 54px;
    border-radius: 999px;
    border: 1px solid var(--color-black, #000000);
    background: var(--color-black, #000000);
    color: var(--color-white, #FFFFFF);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 180ms ease, transform 180ms ease;
  }

  .comment-form__submit:hover {
    background: var(--blog-nav-hover-color, #0f172a);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: 34px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .article-nav__inner {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .article-nav__next {
      justify-self: start;
    }
  }

  @media (max-width: 749px) {
    .author-bio-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

