---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { t } from '../../../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../../../lib/breadcrumbs';

const { locale = 'en' } = Astro.params;
if (locale !== 'en') {
  return new Response('Not found', { status: 404 });
}

const heroBackgroundImage =
  '/images/about/brand-story-hero.webp';

const highlights = [
  {
    title: 'Industry Excellence',
    description:
      'With more than 15 years in IPL device manufacturing, iShine has built a strong record of helping global brands succeed in the beauty-tech market.',
  },
  {
    title: 'Innovation & Technology',
    description:
      'Our modern facilities and ongoing investment in research allow us to deliver IPL devices that reflect the latest advances in performance, safety, and design.',
  },
  {
    title: 'Quality Assurance',
    description:
      'Every stage of production is carefully checked — from prototype to final assembly — to ensure devices meet high standards of reliability and safety.',
  },
  {
    title: 'Global Standards & Trust',
    description:
      'We work to meet international requirements across North America, Europe, and Asia, and are trusted by leading names such as Costco, RoseSkinCo, and KU‑2 Cosmetics.',
  },
];

const reasons = [
  'Comprehensive end-to-end manufacturing solutions',
  'Flexible MOQ to support startups and established brands',
  'Fast prototyping and reliable production timelines',
  'Complete compliance and certification support',
  'Global shipping and logistics expertise',
];
const pageTitle = t(locale, 'nav.brandStory');
const pageDescription = 'Discover the iShine story: 15+ years of IPL device manufacturing excellence, trusted by Costco, RoseSkinCo, and KU2 Cosmetics for OEM and ODM partnerships.';
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.about'), path: '/about' },
  { label: pageTitle },
]);
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription}>
  <div class="space-y-48">
    <section
      class="relative overflow-hidden rounded-2xl bg-slate-900 px-8 py-14 text-white"
      style={`background-image:url(${heroBackgroundImage});background-size:cover;background-position:center;background-blend-mode:overlay;min-height:764px;`}
    >
      <div class="pointer-events-none absolute inset-0 bg-black/40" />
      <div class="relative">
        <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />
      </div>
    </section>

    <section class="space-y-6">
      <div class="max-w-3xl">
        <h1 class="text-3xl font-bold text-slate-900 md:text-4xl">{pageTitle}</h1>
        <p class="mt-4 text-lg text-slate-700">
          Discover the iShine story: from humble beginnings to becoming a trusted global IPL manufacturer
        </p>
        <p class="mt-4 text-lg text-slate-700">
          At iShine, we combine advanced technology with expert craftsmanship to deliver exceptional results. Our team works closely with clients throughout the entire process, ensuring every detail meets your specifications and exceeds market expectations.
        </p>
      </div>
    </section>

    <section class="space-y-8">
      <div class="grid gap-8 md:grid-cols-2">
        {highlights.map((item) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-xl font-semibold text-slate-900">{item.title}</h2>
            <p class="mt-3 text-slate-700">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl bg-slate-50 p-8">
      <h2 class="text-2xl font-bold text-slate-900">Why Choose iShine?</h2>
      <ul class="mt-6 space-y-3 text-slate-700">
        {reasons.map((r) => (
          <li class="flex items-start gap-3">
            <span class="mt-2 h-2 w-2 flex-shrink-0 rounded-2xl bg-sky-600" />
            <span>{r}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/contact')}>Contact Us</a>
        <a class="rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/about')}>Back to About</a>
      </div>
    </section>

    <section class="space-y-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">iShine Core Team</h2>
        <p class="mt-4 text-lg text-slate-700">
          Meet the leadership team driving iShine's mission to deliver world-class IPL manufacturing solutions.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">EA</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Eric Ann</h3>
          <p class="text-sm text-sky-600 font-medium">CEO and Co-founder</p>
          <p class="mt-2 text-sm text-slate-600">Leading strategic vision, business development, and global partnerships.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">SC</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Sarah Chen</h3>
          <p class="text-sm text-sky-600 font-medium">CFO</p>
          <p class="mt-2 text-sm text-slate-600">Overseeing financial strategy, risk management, and operational efficiency.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">MB</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Maurice</h3>
          <p class="text-sm text-sky-600 font-medium">Business Manager</p>
          <p class="mt-2 text-sm text-slate-600">Managing client relationships, sales operations, and market expansion.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">AD</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Amy</h3>
          <p class="text-sm text-sky-600 font-medium">Art Designer</p>
          <p class="mt-2 text-sm text-slate-600">Driving product aesthetics, packaging design, and brand identity creation.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">VP</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Vivian</h3>
          <p class="text-sm text-sky-600 font-medium">Process Project Manager</p>
          <p class="mt-2 text-sm text-slate-600">Coordinating production workflows, timeline management, and process optimization.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm text-center">
          <div class="mx-auto h-24 w-24 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl font-bold text-slate-400">ML</div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Mike Lee</h3>
          <p class="text-sm text-sky-600 font-medium">Production Manager</p>
          <p class="mt-2 text-sm text-slate-600">Leading manufacturing operations, quality control, and supply chain management.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
