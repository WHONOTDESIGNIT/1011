---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../lib/i18n';
import { getLocalizedPath } from '../../../lib/breadcrumbs';

const { locale = 'en' } = Astro.params;
if (locale !== 'en') {
  return new Response('Not found', { status: 404 });
}

const headerTitle = t(locale, 'componentsPower.header.title');
const headerDescription = t(locale, 'componentsPower.header.description');
const introTitle = t(locale, 'componentsPower.intro.title');
const introParagraph = t(locale, 'componentsPower.intro.paragraph');
const overviewTitle = t(locale, 'componentsPower.overview.title');

const core = [
  {
    slug: 'lamp-cartridges',
    title: t(locale, 'componentsPower.core.lamp.title'),
    description: t(locale, 'componentsPower.core.lamp.description'),
    paragraph: t(locale, 'componentsPower.core.lamp.paragraph'),
    image: 'https://source.unsplash.com/u31s74TWOvc/1200x900',
    imageAlt: t(locale, 'componentsPower.core.lamp.imageAlt'),
    cta: t(locale, 'componentsPower.core.lamp.cta'),
    specs: [
      t(locale, 'componentsPower.core.lamp.specs.0'),
      t(locale, 'componentsPower.core.lamp.specs.1'),
      t(locale, 'componentsPower.core.lamp.specs.2'),
      t(locale, 'componentsPower.core.lamp.specs.3'),
    ],
  },
  {
    slug: 'optical-filters',
    title: t(locale, 'componentsPower.core.filter.title'),
    description: t(locale, 'componentsPower.core.filter.description'),
    paragraph: t(locale, 'componentsPower.core.filter.paragraph'),
    image: 'https://source.unsplash.com/9wYdW55NbnY/1200x900',
    imageAlt: t(locale, 'componentsPower.core.filter.imageAlt'),
    cta: t(locale, 'componentsPower.core.filter.cta'),
    specs: [
      t(locale, 'componentsPower.core.filter.specs.0'),
      t(locale, 'componentsPower.core.filter.specs.1'),
      t(locale, 'componentsPower.core.filter.specs.2'),
      t(locale, 'componentsPower.core.filter.specs.3'),
    ],
  },
  {
    slug: 'cooling-system',
    title: t(locale, 'componentsPower.core.cooling.title'),
    description: t(locale, 'componentsPower.core.cooling.description'),
    paragraph: t(locale, 'componentsPower.core.cooling.paragraph'),
    image: 'https://source.unsplash.com/OYW8EUAYokM/1200x900',
    imageAlt: t(locale, 'componentsPower.core.cooling.imageAlt'),
    cta: t(locale, 'componentsPower.core.cooling.cta'),
    specs: [
      t(locale, 'componentsPower.core.cooling.specs.0'),
      t(locale, 'componentsPower.core.cooling.specs.1'),
      t(locale, 'componentsPower.core.cooling.specs.2'),
      t(locale, 'componentsPower.core.cooling.specs.3'),
    ],
  },
  {
    slug: 'power-supply',
    title: t(locale, 'componentsPower.core.power.title'),
    description: t(locale, 'componentsPower.core.power.description'),
    paragraph: t(locale, 'componentsPower.core.power.paragraph'),
    image: 'https://source.unsplash.com/mrTVz_fosMY/1200x900',
    imageAlt: t(locale, 'componentsPower.core.power.imageAlt'),
    cta: t(locale, 'componentsPower.core.power.cta'),
    specs: [
      t(locale, 'componentsPower.core.power.specs.0'),
      t(locale, 'componentsPower.core.power.specs.1'),
      t(locale, 'componentsPower.core.power.specs.2'),
      t(locale, 'componentsPower.core.power.specs.3'),
    ],
  },
];

const qualityTitle = t(locale, 'componentsPower.quality.title');
const qualityPartnership = t(locale, 'componentsPower.quality.partnership');
const qualityBlocks = [
  {
    title: t(locale, 'componentsPower.qualityBlocks.durability.title'),
    description: t(locale, 'componentsPower.qualityBlocks.durability.description'),
  },
  {
    title: t(locale, 'componentsPower.qualityBlocks.safety.title'),
    description: t(locale, 'componentsPower.qualityBlocks.safety.description'),
  },
  {
    title: t(locale, 'componentsPower.qualityBlocks.performance.title'),
    description: t(locale, 'componentsPower.qualityBlocks.performance.description'),
  },
  {
    title: t(locale, 'componentsPower.qualityBlocks.compliance.title'),
    description: t(locale, 'componentsPower.qualityBlocks.compliance.description'),
  },
];

const customizationTitle = t(locale, 'componentsPower.customization.title');
const customizationDescription = t(locale, 'componentsPower.customization.description');
const ctaTitle = t(locale, 'componentsPower.cta.title');
const ctaDescription = t(locale, 'componentsPower.cta.description');
const ctaButton = t(locale, 'componentsPower.cta.button');
---

<BaseLayout title={headerTitle} lang={locale} description={headerDescription || 'Explore iShine\'s IPL device components: lamp cartridges, optical filters, cooling systems, and power supplies for OEM and ODM manufacturing.'}>
  <div class="space-y-48">
    <section class="relative overflow-hidden rounded-2xl bg-slate-900 px-8 py-14 text-white">
      <div class="pointer-events-none absolute inset-0 opacity-30" style={`background-image:url(https://source.unsplash.com/OWHh5XOF3Nc/1600x900);background-size:cover;background-position:center;`} />
      <div class="pointer-events-none absolute inset-0 bg-black/40" />
      <div class="relative">
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{headerTitle}</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-200">{headerDescription}</p>
      </div>
    </section>

    <section class="space-y-10">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-slate-900">{introTitle}</h2>
        <p class="mx-auto mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">{introParagraph}</p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="aspect-[16/9]">
          <img src="https://source.unsplash.com/IYgYQxx_FYU/1600x900" alt={t(locale, 'componentsPower.diagram.alt')} loading="lazy" class="h-full w-full object-cover" />
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What are the core components of a home-use IPL device?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        A home-use IPL device is built from several core subsystems that directly affect safety, comfort, and performance. The flash source is typically a xenon lamp cartridge, engineered for stable output and high flash counts. Optical filters shape the emitted spectrum by blocking unwanted wavelengths (including UV) and selecting bands suited to hair-reduction positioning. A cooling system manages skin-contact comfort and heat load; options include sapphire ice plates and semiconductor (TEC) cooling designs used in premium configurations. The power supply provides consistent voltage delivery and protects the device through electrical design choices such as insulation, grounding, and thermal safeguards. For private-label programs, these components are selected as a matched platform so the final device can meet target-market requirements, maintain consistent batch performance, and support documentation and verification during scale production. iShine integrates these component choices into OEM/ODM builds with packaging and export delivery.
      </p>
    </section>

    <section class="space-y-8">
      <h2 class="text-center text-3xl font-bold text-slate-900">{overviewTitle}</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {core.map((item) => (
          <a class="block rounded-xl border border-slate-200 bg-white p-6 shadow-sm hover:shadow-md" href={getLocalizedPath(locale, '/components/' + item.slug)}>
            <div class="mb-4 overflow-hidden rounded-xl bg-slate-100" style="aspect-ratio:16/10">
              <img src={item.image} alt={item.imageAlt} loading="lazy" class="h-full w-full object-cover" />
            </div>
            <div class="text-xl font-semibold">{item.title}</div>
            <div class="mt-2 text-sm text-slate-700">{item.description}</div>
            <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-slate-700">
              {item.specs.map((s) => (
                <li>{s}</li>
              ))}
            </ul>
            <div class="mt-4 text-sm font-medium text-slate-900">View details →</div>
          </a>
        ))}
      </div>
    </section>

    <section class="space-y-16">
      {core.map((item, idx) => (
        <div class="grid gap-10 md:grid-cols-2 md:items-center">
          <div class={idx % 2 === 0 ? 'md:order-2' : 'md:order-1'}>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <img src={item.image} alt={item.imageAlt} loading="lazy" class="h-full w-full object-cover" />
              </div>
            </div>
          </div>
          <div class={idx % 2 === 0 ? 'md:order-1' : 'md:order-2'}>
            <h3 class="text-2xl font-bold text-slate-900">{item.title}</h3>
            <p class="mt-4 text-slate-700">{item.paragraph}</p>
            <ul class="mt-6 space-y-2 text-slate-700">
              {item.specs.map((s) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span class="text-sm">{s}</span>
                </li>
              ))}
            </ul>
            <div class="mt-8">
              <a class="inline-flex rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/components/' + item.slug)}>
                {item.cta}
              </a>
            </div>
          </div>
        </div>
      ))}
    </section>

    <section class="rounded-2xl bg-slate-50 px-8 py-12">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-slate-900">{qualityTitle}</h2>
        <p class="mx-auto mt-3 max-w-2xl text-slate-700">{qualityPartnership}</p>
      </div>
      <div class="mx-auto mt-10 max-w-5xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="aspect-[16/9] bg-slate-100">
          <img
            src="https://source.unsplash.com/76wMkjguUEA/1600x900"
            alt="Component Quality Determines Device Performance"
            loading="lazy"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {qualityBlocks.map((b) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="text-lg font-semibold">{b.title}</div>
            <div class="mt-2 text-sm text-slate-700">{b.description}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-8">
      <h2 class="text-2xl font-bold text-slate-900">{customizationTitle}</h2>
      <p class="mt-3 max-w-3xl text-slate-700">{customizationDescription}</p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/contact')}>{ctaButton}</a>
        <a class="rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/services')}>View services</a>
      </div>
    </section>

    <section class="rounded-2xl bg-slate-900 px-8 py-12 text-white">
      <h2 class="text-2xl font-bold">{ctaTitle}</h2>
      <p class="mt-3 max-w-3xl text-slate-200">{ctaDescription}</p>
      <div class="mt-6">
        <a class="inline-flex rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/contact')}>{ctaButton}</a>
      </div>
    </section>
  </div>
</BaseLayout>
