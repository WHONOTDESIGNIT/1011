---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../lib/i18n';
import { getLocalizedPath } from '../../../lib/breadcrumbs';
import { Image } from 'astro:assets';

const { locale = 'en' } = Astro.params;
if (locale !== 'en') {
  return new Response('Not found', { status: 404 });
}

const products = [
  { slug: 'lumi', nameKey: 'nav.lumi', tagline: 'Smart App Control', firstImage: '/images/products/lumi/lumi_ipl_device_2.jpg' },
  { slug: 'lumi-2', nameKey: 'nav.lumi2', tagline: 'Smart Skin Sensor + Chills Skin to 10℃', firstImage: '/images/products/lumi-2/Lumi2_Gallery_Hero_1.webp' },
  { slug: 'venus', nameKey: 'nav.venus', tagline: 'Ice Feeling Hair Removal Device', firstImage: '/images/products/sapphire-ipl-white.webp' },
  { slug: 'hestia', nameKey: 'nav.hestia', tagline: 'Smart App-Connected Hair Removal', firstImage: '/images/products/hestia-app-control-ipl-side-view..webp' },
  { slug: 'alpha', nameKey: 'nav.alpha', tagline: 'To be launched', firstImage: '/images/products/alpha/alpha_ipl_device.webp' },
  { slug: 'emerald', nameKey: 'nav.emerald', tagline: 'Advanced Cooling for Sensitive Skin', firstImage: '/images/products/white-color-emerald-style-ipl.webp' },
  { slug: 'euno', nameKey: 'nav.euno', tagline: 'Compact & Portable Design', firstImage: '/images/products/euno/euno-ipl-device-white-black-colors.webp' },
  { slug: 'themis', nameKey: 'nav.themis', tagline: 'Ice Feeling Professional Treatment', firstImage: '/images/products/themis/themis_handheld_ipl_hair_removal_front_view.webp' },
  { slug: 'hebe', nameKey: 'nav.hebe', tagline: 'AI-Powered Skin Detection', firstImage: '/images/products/Hebe/Hebe-ipl-device-front-view.webp' },
  { slug: 'eirene', nameKey: 'nav.eirene', tagline: 'Gentle Care for Sensitive Skin', firstImage: '/images/products/eirene/eirene_ipl_device.jpg' },
  { slug: 'wooden', nameKey: 'nav.wooden', tagline: 'Luxury Collection with Wooden Finish', firstImage: '/images/products/luxury/luxury-ipl-device-white.webp' },
];

// Keep data intact but filter out Lumi-2 from display
const visibleProducts = products.filter(p => p.slug !== 'lumi-2');
---

<BaseLayout title="Products" lang={locale} description="iShine IPL product range: Lumi, Venus, Hestia, Themis, Hebe, Eirene, Emerald, Euno, and Alpha devices available for OEM and ODM customization.">
  <div class="space-y-36">
    <section class="relative w-screen left-1/2 -translate-x-1/2 overflow-hidden -mt-[160px] pt-[160px] min-h-[400px] md:min-h-[500px] lg:min-h-[600px]">
      <Image
        src="/images/products/ipl-products-banner.webp"
        alt="IPL Products"
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-black/20" />
      <div class="relative z-10 flex h-full items-end px-6 pb-10 md:px-12">
        <h1 class="text-4xl font-bold tracking-tight text-white md:text-5xl lg:text-6xl">IPL Products</h1>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What does iShine manufacture?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        iShine Technology Ltd. is a B2B OEM/ODM manufacturer of home-use IPL hair removal devices. Since 2008, we’ve produced 500,000+ units for 50+ global clients, supporting private-label programs from concept design and rapid prototyping (often 1–4 weeks) through compliance documentation, mass production, custom packaging, and global delivery. Our manufacturing system aligns with ISO 13485 and MDSAP requirements, and we support FDA-cleared device programs (510(k)) and CE-marked configurations for international markets. Brands and retailers choose iShine when they need consistent energy output, cooling options (including ice plate), and scalable capacity to ship to North America, Europe, and the Middle East.
      </p>
    </section>

    <section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {visibleProducts.map((product) => (
        <a
          class="product-card flex flex-col overflow-hidden rounded-xl border-2 border-black bg-white shadow-sm transition-all hover:shadow-md"
          href={getLocalizedPath(locale, '/products/' + product.slug)}
        >
          <div class="relative bg-slate-100" style="aspect-ratio:1000/806">
            <img
              class="h-full w-full object-cover"
              src={product.firstImage}
              alt={t(locale, product.nameKey)}
              loading="lazy"
            />
          </div>
          <div class="flex flex-col justify-end p-3" style="aspect-ratio:1000/194">
            <div>
              <h2 class="text-xl font-semibold text-slate-900">{t(locale, product.nameKey)}</h2>
              <p class="mt-1 text-sm text-slate-700">{product.tagline}</p>
            </div>
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
