function buildCitableProductSummary(productSlug: string, product: ProductData) {
  const specMap = new Map(product.specs.map((s) => [s.label.toLowerCase(), s.value]));
  const energy = specMap.get('energy');
  const flashes = specMap.get('lamp');
  const window = specMap.get('window');
  const wavelength = specMap.get('wavelength');
  const cooling = specMap.get('cooling');
  const connectivity = specMap.get('connectivity');
  const skinDetection = specMap.get('skin detection');
  const type = specMap.get('type');

  const lines: string[] = [];
  lines.push(`${product.name} is an OEM/ODM-ready home-use IPL device platform for private-label brands that need a clear feature story and repeatable manufacturing.`);
  lines.push(`It is positioned as "${product.tagline}" and is typically customized through cosmetics, colorways, logo printing, packaging, manuals, labeling, and accessories to match retail, distributor, or DTC requirements.`);
  const specBits = [
    type ? `type: ${type}` : null,
    cooling ? `cooling: ${cooling}` : null,
    skinDetection ? `skin detection: ${skinDetection}` : null,
    connectivity ? `connectivity: ${connectivity}` : null,
    energy ? `energy: ${energy}` : null,
    flashes ? `flash count: ${flashes}` : null,
    window ? `treatment window: ${window}` : null,
    wavelength ? `wavelength band: ${wavelength}` : null,
  ].filter(Boolean);
  if (specBits.length) {
    lines.push(`Typical configuration points include ${specBits.join(', ')}.`);
  }
  if (product.colors?.length) {
    lines.push(`Brand aesthetics can be supported with multiple color options such as ${product.colors.join(', ')}.`);
  }
  lines.push(`Platform-based sampling can often start in 1-4 weeks depending on scope, while deeper customization adds time for validation and production planning.`);
  lines.push(`For launch planning, ${productSlug} is commonly selected to balance user comfort, differentiation, and scalable production for global distribution.`);

  return {
    question: `What is ${product.name} designed for?`,
    answer: lines.join(' '),
  };
}

const product = products[slug];
if (!product) {
  return new Response('Not found', { status: 404 });
}

const citable = buildCitableProductSummary(slug, product);

const pageTitle = product.name;
const pageDescription = product.description;
const canonical = `https://iplmanufacturer.com/${locale}/products/${slug}`;
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.products'), path: '/products' },
  { label: pageTitle },
]);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href ? `https://iplmanufacturer.com${item.href}` : canonical,
  })),
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: product.gallery.map((img) => `https://iplmanufacturer.com${img}`),
  brand: {
    '@type': 'Brand',
    name: 'iShine',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
  },
  ...(product.badge ? { award: product.badge } : {}),
};
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="space-y-48">
    <section class="space-y-8">
      <div class="px-6 pt-6">
        <Breadcrumb items={breadcrumbs} locale={locale} />
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4">
          <div class="overflow-hidden rounded-2xl bg-slate-100">
            <img
              src={product.heroImage}
              alt={product.name}
              class="h-full w-full object-cover"
              style="aspect-ratio:1/1;max-height:500px;"
              loading="eager"
            />
          </div>
          {product.gallery.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-2">
              {product.gallery.map((img) => (
                <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-xl bg-slate-100">
                  <img
                    src={img}
                    alt={`${product.name} gallery`}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <div class="space-y-6">
          <div class="space-y-3">
            {product.badge && (
              <span class="inline-block rounded-full bg-sky-600 px-4 py-1 text-xs font-semibold uppercase tracking-wider text-white">
                {product.badge}
              </span>
            )}
            <h1 class="text-4xl font-bold text-slate-900 md:text-5xl">{product.name}</h1>
            <p class="text-xl text-sky-600 font-medium">{product.tagline}</p>
            <p class="text-base leading-relaxed text-slate-700">{product.description}</p>
          </div>

          <section class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{citable.question}</h2>
            <p class="mt-3 text-slate-700">{citable.answer}</p>
          </section>

          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Specifications</h2>
            <dl class="mt-4 divide-y divide-slate-100">
              {product.specs.map((spec) => (
                <div class="flex justify-between py-3 text-sm">
                  <dt class="text-slate-600">{spec.label}</dt>
                  <dd class="font-medium text-slate-900 text-right ml-4">{spec.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          {product.colors.length > 0 && (
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <h2 class="text-lg font-semibold text-slate-900">Available Colors</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {product.colors.map((color) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-1.5 text-sm text-slate-700">{color}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">Key Features</h2>
        <p class="mt-3 text-lg text-slate-700">What makes {product.name} the right choice for your brand.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {product.features.map((feature) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-slate-900">{feature.title}</h3>
            <p class="mt-3 text-slate-700">{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl bg-gradient-to-br from-sky-600 to-blue-700 px-8 py-14 text-center text-white">
      <h2 class="text-3xl font-bold md:text-4xl">Interested in {product.name}?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Contact our team to discuss customization options, MOQ, pricing, and sample requests for your brand.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a class="rounded-lg bg-white px-8 py-3 font-semibold text-sky-700 transition hover:bg-sky-50" href={getLocalizedPath(locale, '/contact')}>Request Free Sample</a>
        <a class="rounded-lg border border-white/30 px-8 py-3 font-semibold text-white transition hover:bg-white/10" href={getLocalizedPath(locale, '/products')}>View All Products</a>
      </div>
    </section>
  </div>
</BaseLayout>
