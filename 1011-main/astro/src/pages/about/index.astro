---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { responsiveImageSources } from '../../lib/netlify-images';

const locale = 'en';
const values = [
  {
    title: 'Mission Driven',
    description: 'Empowering brands with innovative IPL solutions that transform the beauty industry.',
  },
  {
    title: 'Customer Focused',
    description: 'Building lasting partnerships through exceptional service and reliable delivery.',
  },
  {
    title: 'Innovation First',
    description: 'Continuously advancing IPL technology to meet evolving market demands.',
  },
  {
    title: 'Quality Excellence',
    description: 'Maintaining the highest standards in manufacturing and quality control.',
  },
];

const milestones = [
  { year: '2008', event: 'Founded in Guangzhou, China' },
  { year: '2012', event: 'First international partnership' },
  { year: '2015', event: 'FDA clearance achieved' },
  { year: '2018', event: 'Partnership with Costco Canada' },
  { year: '2020', event: '500,000 devices milestone' },
  { year: '2023', event: 'Expanded smart IPL technology' },
];
const pageTitle = 'About iShine';
const pageDescription = 'iShine is an IPL hair removal device manufacturer providing OEM and ODM services for beauty brands, from product design to global delivery.';
const aboutFacilityImage = responsiveImageSources(
  'https://images.pexels.com/photos/3825569/pexels-photo-3825569.jpeg?auto=compress&cs=tinysrgb&w=1200',
);
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription}>
  <div class="space-y-48">
    <section class="rounded-2xl bg-slate-50 px-8 py-12">
      <h1 class="text-4xl font-bold tracking-tight">About iShine</h1>
      <p class="mt-4 max-w-3xl text-lg text-slate-700">
        Leading manufacturer of IPL hair removal devices, dedicated to helping brands succeed from concept to market.
      </p>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What is iShine Technology Ltd.?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        iShine Technology Ltd. is a B2B OEM/ODM manufacturer of home-use IPL hair removal devices that supports private-label programs for beauty brands and retailers. Founded in 2008 in Guangzhou, China, iShine provides end-to-end services across product design, prototyping, scalable production, packaging, compliance planning, and export delivery. The company references international market requirements such as FDA and CE pathways and operates with quality-system alignment including ISO 13485. iShine reports 15+ years in operation, 500,000+ devices produced, and 50+ global client partnerships, shipping to 20+ countries across North America, Europe, and the Middle East. Its work focuses on manufacturing repeatability and brand-ready execution so partners can launch and scale IPL products with consistent quality.
      </p>
    </section>

    <section class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <h2 class="text-2xl font-semibold">A full-stack IPL manufacturing partner for global beauty brands</h2>
        <div class="mt-4 space-y-4 text-slate-700">
          <p>
            <strong>Entity:</strong> iShine Technology Ltd.<br />
            <strong>Industry:</strong> Home-use IPL hair removal device manufacturing (OEM/ODM).<br />
            <strong>Headquarters:</strong> Guangzhou, China.<br />
            <strong>Certifications:</strong> FDA cleared, CE certified, ISO 13485.
          </p>
          <p>
            <strong>What iShine does:</strong> Partners with global retailers, beauty brands, and sourcing professionals to design, certify, produce, and deliver private-label IPL hair removal devices. Serves as both OEM (build to spec) and ODM (design and build) manufacturer.
          </p>
          <p>
            <strong>Key partners:</strong> Costco Canada (retail), RoseSkinCo USA (beauty e-commerce), KU2 Cosmetics Germany (cosmetics retail).
          </p>
          <p>
            <strong>Capabilities:</strong> Concept design and industrial design; rapid prototyping and tooling; large-scale production and assembly; custom packaging and branding; compliance documentation (FDA, CE, MDSAP); global logistics and warehousing.
          </p>
          <p>
            <strong>Client types served:</strong> Brand owners launching new IPL product lines; product managers expanding existing beauty portfolios; sourcing specialists evaluating contract manufacturers; retailers developing private-label beauty-tech programs.
          </p>
          <p>
            <strong>Geographic reach:</strong> North America, Europe, Middle East. Ships to 20+ countries.
          </p>
          <p>
            <strong>Track record:</strong> 15+ years in operation; 500,000+ devices produced; 50+ global brand partners; successful Costco Canada shelf placement.
          </p>
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
        <picture>
          <source srcset={aboutFacilityImage.avifSrcSet} sizes="(min-width: 1024px) 50vw, 100vw" type="image/avif" />
          <source srcset={aboutFacilityImage.webpSrcSet} sizes="(min-width: 1024px) 50vw, 100vw" type="image/webp" />
          <img
            src={aboutFacilityImage.src}
            srcset={aboutFacilityImage.webpSrcSet}
            sizes="(min-width: 1024px) 50vw, 100vw"
            alt="iShine Manufacturing Facility"
            loading="lazy"
            decoding="async"
            width="1200"
            height="900"
            class="h-full w-full object-cover"
          />
        </picture>
      </div>
    </section>

    <section>
      <div class="mb-8">
        <h2 class="text-2xl font-semibold">Our Core Values</h2>
        <p class="mt-2 max-w-2xl text-slate-700">The principles that guide everything we do.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {values.map((value) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold">{value.title}</h3>
            <p class="mt-2 text-sm text-slate-700">{value.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-8 text-center">
        <div class="text-4xl font-bold">500K+</div>
        <div class="mt-1 text-sm text-slate-700">Devices Produced</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-8 text-center">
        <div class="text-4xl font-bold">50+</div>
        <div class="mt-1 text-sm text-slate-700">Global Clients</div>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-8 text-center">
        <div class="text-4xl font-bold">15+</div>
        <div class="mt-1 text-sm text-slate-700">Years Experience</div>
      </div>
    </section>

    <section class="rounded-2xl bg-slate-900 px-8 py-12 text-white">
      <div class="mb-8">
        <h2 class="text-2xl font-semibold">Our Journey</h2>
        <p class="mt-2 max-w-2xl text-slate-200">Milestones that shaped iShine into the trusted manufacturer we are today.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {milestones.map((milestone) => (
          <div class="rounded-xl bg-white/10 p-6">
            <div class="text-2xl font-bold text-sky-300">{milestone.year}</div>
            <div class="mt-2 text-slate-200">{milestone.event}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
