---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { t } from '../../lib/i18n';
import { getLocalizedPath, buildBreadcrumbs } from '../../lib/breadcrumbs';
import { Image } from 'astro:assets';
import { netlifyImageUrl, responsiveImageSources } from '../../lib/netlify-images';



const locale = 'en'; const { slug } = Astro.params;

const namespaceBySlug: Record<string, string> = {
  'lamp-cartridges': 'componentsLamp',
  'optical-filters': 'componentsFilter',
  'cooling-system': 'componentsCooling',
  'power-supply': 'componentsPower',
};

const ns = namespaceBySlug[slug];
if (!ns) return new Response('Not found', { status: 404 });

const title = t(locale, `${ns}.header.title`);
const description = t(locale, `${ns}.header.description`);

const heroImageBySlug: Record<string, string> = {
  'lamp-cartridges': '/images/components/lamp-cartridge-closeup.jpg',
  'optical-filters': '/images/components/optical-filters.jpg',
  'cooling-system': '/images/components/cooling-system-closeup.jpg',
  'power-supply': '/images/components/power-supply.jpg',
};
const heroImage = heroImageBySlug[slug] ?? '/images/components/ipl-device-diagram.jpg';
const heroBackgroundImage = netlifyImageUrl(heroImage, { width: 1600, format: 'webp', quality: 80 });
const heroImageSources = responsiveImageSources(heroImage, [400, 800, 1200, 1600], 1200);
const componentsDiagramImage = responsiveImageSources('/images/components/ipl-device-diagram.jpg', [400, 800, 1200, 1600], 1200);

const specsRows =
  ns === 'componentsCooling' || ns === 'componentsFilter' || ns === 'componentsLamp'
    ? Array.from({ length: 6 }, (_, i) => ({
        parameter: t(locale, `${ns}.specs.rows.${i}.parameter`),
        value: t(locale, `${ns}.specs.rows.${i}.value`),
        notes: t(locale, `${ns}.specs.rows.${i}.description`),
      }))
    : [];

const complianceItems =
  ns === 'componentsCooling' || ns === 'componentsFilter' || ns === 'componentsLamp'
    ? [
        t(locale, `${ns}.compliance.items.ce`),
        t(locale, `${ns}.compliance.items.iso13485`),
        t(locale, `${ns}.compliance.items.fda`),
        t(locale, `${ns}.compliance.items.iec60601`),
        t(locale, `${ns}.compliance.items.mdr`),
      ]
    : [];

const showIntro = ns !== 'componentsPower' || (t(locale, `${ns}.intro.title`) && t(locale, `${ns}.intro.paragraph`));
const currentBreadcrumbLabel =
  slug === 'cooling-system'
    ? t(locale, `${ns}.breadcrumb.cooling`)
    : slug === 'optical-filters'
      ? t(locale, `${ns}.breadcrumb.filter`)
      : slug === 'lamp-cartridges'
        ? t(locale, `${ns}.breadcrumb.lamp`)
        : title;
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.products'), path: '/products' },
  { label: t(locale, 'nav.iplComponentsCatalogue'), path: '/components' },
  { label: currentBreadcrumbLabel },
]);
---

<BaseLayout title={title} lang={locale} description={description}>
  <div class="space-y-48">
    <section class="relative overflow-hidden rounded-2xl bg-slate-900 px-8 py-14 text-white">
      <div class="pointer-events-none absolute inset-0 opacity-30" style={`background-image:url(${heroBackgroundImage});background-size:cover;background-position:center;`} />
      <div class="pointer-events-none absolute inset-0 bg-black/40" />
      <div class="relative">
        <Breadcrumb items={breadcrumbs} variant="dark" locale={locale} />
        <h1 class="mt-4 text-3xl font-bold tracking-tight md:text-4xl">{title}</h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-200">{description}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/contact')}>
            {ns === 'componentsCooling'
              ? t(locale, `${ns}.cta.button`)
              : ns === 'componentsFilter'
                ? t(locale, `${ns}.cta.button`)
                : ns === 'componentsLamp'
                  ? t(locale, `${ns}.cta.button`)
                  : t(locale, 'componentsPower.cta.button')}
          </a>
          <a class="rounded border border-white/30 px-4 py-2 text-sm font-medium text-white" href={getLocalizedPath(locale, '/components')}>Back to components</a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="aspect-[16/9] bg-slate-100">
          <picture>
            <source srcset={heroImageSources.avifSrcSet} sizes="(min-width: 1024px) 72rem, 100vw" type="image/avif" />
            <source srcset={heroImageSources.webpSrcSet} sizes="(min-width: 1024px) 72rem, 100vw" type="image/webp" />
            <img
              src={heroImageSources.src}
              srcset={heroImageSources.webpSrcSet}
              sizes="(min-width: 1024px) 72rem, 100vw"
              alt={title}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="1600"
              height="900"
              class="h-full w-full object-cover"
            />
          </picture>
        </div>
      </div>
    </section>

    {slug === 'lamp-cartridges' && (
      <section class="mx-auto max-w-6xl px-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
        <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What is an IPL lamp cartridge and why does it matter?</h3>
        <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
          An IPL lamp cartridge is the flash source that generates intense pulsed light in a home-use IPL device. Most platforms use a xenon flash lamp tube paired with optical filtering so the emitted spectrum targets hair pigment while reducing unwanted wavelengths such as UV. Lamp design affects pulse stability, energy consistency, heat load, and expected flash count across the device lifetime (commonly 500,000-999,000 flashes depending on platform). For private-label programs, a well-specified lamp cartridge helps reduce batch-to-batch variation and supports repeatable performance positioning, because the lamp is central to how energy is delivered through the treatment window. iShine integrates lamp selection with filters, cooling, and safety interlocks so the final device can be manufactured consistently and supported with verification and documentation for target-market requirements.
        </p>
      </section>
    )}

    {slug === 'optical-filters' && (
      <section class="mx-auto max-w-6xl px-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
        <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What do optical filters do in an IPL device?</h3>
        <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
          Optical filters in an IPL device shape the light output by blocking unwanted wavelengths and transmitting bands that match the intended treatment positioning. In practical terms, filters help reduce UV exposure and can tune the effective wavelength range delivered through the treatment window (for example, common cut-on options like 550 nm, 570 nm, or 600 nm in supported configurations). Filter design influences safety margin across skin tones, perceived comfort, and the balance between efficacy and tolerability at different energy settings. For OEM/ODM production, filter selection is treated as part of a matched optical stack with the lamp tube and window materials, because small changes can affect output consistency and verification results. iShine supports filter configuration within private-label programs to align performance targets with target-market documentation and manufacturing repeatability.
        </p>
      </section>
    )}

    {slug === 'cooling-system' && (
      <section class="mx-auto max-w-6xl px-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
        <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">Why does cooling matter in a home-use IPL device?</h3>
        <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
          Cooling is a key design factor for home-use IPL devices because it improves skin-contact comfort and helps manage thermal load during repeated flashes. Premium configurations often use a sapphire ice plate or a semiconductor (TEC) cooling module to pull heat away from the treatment window, with some designs targeting skin-contact temperatures around ~10°C. Better thermal management can make higher-energy settings feel more tolerable and can reduce the risk of user discomfort when treating sensitive areas, which supports better session consistency. Cooling choices also affect industrial design, power consumption, assembly complexity, and cost, so the right system depends on brand positioning and target-market requirements. For OEM/ODM programs, iShine integrates the cooling approach with lamp, filter, temperature sensing, and safety interlocks so the final device maintains stable performance across production batches and supports verification and documentation for distribution.
        </p>
      </section>
    )}

    {slug === 'power-supply' && (
      <section class="mx-auto max-w-6xl px-6">
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
        <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What does the power supply do in an IPL device?</h3>
        <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
          The power supply is the electrical subsystem that enables stable, repeatable energy delivery for IPL pulses. It converts mains input to controlled outputs used by the lamp driver, cooling modules, and control electronics, often supporting global input ranges like 100-240V AC for international distribution. A well-designed power system supports consistent pulse timing and energy stability while protecting the device through insulation design, thermal management, and electrical safety safeguards. For global private-label launches, power design must also account for regional plug standards and the final packaging configuration, such as included plug types and adapters. In OEM/ODM production, iShine aligns the power supply design with optical and cooling choices so the complete device can pass verification steps and maintain predictable performance across manufacturing batches.
        </p>
      </section>
    )}

    {showIntro && (
      <section class="space-y-10">
        <div class="text-center">
          <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.intro.title`)}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">{t(locale, `${ns}.intro.paragraph`)}</p>
        </div>

        {ns === 'componentsPower' && (
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[16/9]">
              <picture>
                <source srcset={componentsDiagramImage.avifSrcSet} sizes="(min-width: 1024px) 72rem, 100vw" type="image/avif" />
                <source srcset={componentsDiagramImage.webpSrcSet} sizes="(min-width: 1024px) 72rem, 100vw" type="image/webp" />
                <img
                  src={componentsDiagramImage.src}
                  srcset={componentsDiagramImage.webpSrcSet}
                  sizes="(min-width: 1024px) 72rem, 100vw"
                  alt={t(locale, 'componentsPower.diagram.alt')}
                  width="1600"
                  height="900"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                />
              </picture>
            </div>
          </div>
        )}
      </section>
    )}

    {ns === 'componentsCooling' && (
      <div class="space-y-16">
        <section class="rounded-2xl bg-sky-50 px-8 py-12">
          <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
            <div>
              <h2 class="text-2xl font-bold text-slate-900">{t(locale, `${ns}.highlight.whyTitle`)}</h2>
              <p class="mt-4 text-slate-700">{t(locale, `${ns}.highlight.paragraph`)}</p>
              <ul class="mt-6 space-y-3 text-slate-700">
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.comfort`)}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.safety`)}</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-2xl bg-slate-900" />
                  <span>{t(locale, `${ns}.highlight.items.performance`)}</span>
                </li>
              </ul>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <Image src="/images/components/cooling-system-closeup.jpg" alt={t(locale, `${ns}.highlight.imageAlt`)} loading="lazy" class="h-full w-full object-cover" width={1200} height={900} />
              </div>
            </div>
          </div>
        </section>

        <section class="space-y-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.tech.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.tech.description`)}</p>
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {[
              { title: t(locale, `${ns}.tech.items.plates.title`), description: t(locale, `${ns}.tech.items.plates.description`) },
              { title: t(locale, `${ns}.tech.items.sapphire.title`), description: t(locale, `${ns}.tech.items.sapphire.description`) },
              { title: t(locale, `${ns}.tech.items.semiconductor.title`), description: t(locale, `${ns}.tech.items.semiconductor.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-6">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.specs.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.specs.description`)}</p>
          </div>
          <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50">
                <tr>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.parameter`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.value`)}</th>
                  <th class="px-4 py-3 text-left font-semibold text-slate-900">{t(locale, `${ns}.specs.table.notes`)}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {specsRows.map((row, idx) => (
                  <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="px-4 py-3 font-medium text-slate-900">{row.parameter}</td>
                    <td class="px-4 py-3 text-slate-700">{row.value}</td>
                    <td class="px-4 py-3 text-slate-600">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <div class="text-sm italic text-slate-600">{t(locale, `${ns}.specs.footnote`)}</div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.customization.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.customization.description`)}</p>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.customization.blocks.plates.title`), description: t(locale, `${ns}.customization.blocks.plates.description`) },
              { title: t(locale, `${ns}.customization.blocks.sapphire.title`), description: t(locale, `${ns}.customization.blocks.sapphire.description`) },
              { title: t(locale, `${ns}.customization.blocks.integration.title`), description: t(locale, `${ns}.customization.blocks.integration.description`) },
              { title: t(locale, `${ns}.customization.blocks.temperature.title`), description: t(locale, `${ns}.customization.blocks.temperature.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.applications.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.applications.description`)}</p>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {[
              { title: t(locale, `${ns}.applications.items.home.title`), description: t(locale, `${ns}.applications.items.home.description`) },
              { title: t(locale, `${ns}.applications.items.multi.title`), description: t(locale, `${ns}.applications.items.multi.description`) },
              { title: t(locale, `${ns}.applications.items.pro.title`), description: t(locale, `${ns}.applications.items.pro.description`) },
              { title: t(locale, `${ns}.applications.items.sensitive.title`), description: t(locale, `${ns}.applications.items.sensitive.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-8">
          <h2 class="text-2xl font-bold text-slate-900">{t(locale, `${ns}.compliance.title`)}</h2>
          <p class="mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.compliance.paragraph`)}</p>
          <ul class="mt-6 grid gap-3 md:grid-cols-2">
            {complianceItems.map((item) => (
              <li class="rounded-lg bg-slate-50 px-4 py-3 text-sm text-slate-700">{item}</li>
            ))}
          </ul>
        </section>

        <section class="space-y-6">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.visuals.title`)}</h2>
          <div class="grid gap-6 md:grid-cols-2">
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <Image src="/images/components/cooling-plate-diagram.jpg" alt={t(locale, `${ns}.visuals.images.plate.alt`)} loading="lazy" class="h-full w-full object-cover" width={1200} height={900} />
              </div>
              <div class="p-4 text-sm text-slate-700">
                <div class="font-semibold">{t(locale, `${ns}.visuals.images.plate.title`)}</div>
                <div class="mt-1 text-slate-600">{t(locale, `${ns}.visuals.images.plate.caption`)}</div>
              </div>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div class="aspect-[4/3]">
                <Image src="/images/components/ipl-cooling-integration.jpg" alt={t(locale, `${ns}.visuals.images.integration.alt`)} loading="lazy" class="h-full w-full object-cover" width={1200} height={900} />
              </div>
              <div class="p-4 text-sm text-slate-700">
                <div class="font-semibold">{t(locale, `${ns}.visuals.images.integration.title`)}</div>
                <div class="mt-1 text-slate-600">{t(locale, `${ns}.visuals.images.integration.caption`)}</div>
              </div>
            </div>
          </div>
        </section>

        <section class="rounded-2xl bg-slate-50 px-8 py-12">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-slate-900">{t(locale, `${ns}.quality.title`)}</h2>
            <p class="mx-auto mt-3 max-w-3xl text-slate-700">{t(locale, `${ns}.quality.paragraph`)}</p>
          </div>
          <div class="mt-6 text-center text-sm text-slate-700">
            <div class="font-semibold">{t(locale, `${ns}.quality.intertek`)}</div>
            <div class="mt-1 text-slate-600">{t(locale, `${ns}.quality.intertekDesc`)}</div>
          </div>
          <div class="mt-10 grid gap-6 md:grid-cols-2">
            {[
              { title: t(locale, `${ns}.quality.blocks.stability.title`), description: t(locale, `${ns}.quality.blocks.stability.description`) },
              { title: t(locale, `${ns}.quality.blocks.longterm.title`), description: t(locale, `${ns}.quality.blocks.longterm.description`) },
              { title: t(locale, `${ns}.quality.blocks.contact.title`), description: t(locale, `${ns}.quality.blocks.contact.description`) },
              { title: t(locale, `${ns}.quality.blocks.cycling.title`), description: t(locale, `${ns}.quality.blocks.cycling.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-2xl bg-slate-900 px-8 py-12 text-white">
          <h2 class="text-2xl font-bold">{t(locale, `${ns}.cta.title`)}</h2>
          <p class="mt-3 max-w-3xl text-slate-200">{t(locale, `${ns}.cta.description`)}</p>
          <div class="mt-6">
            <a class="inline-flex rounded bg-white px-4 py-2 text-sm font-medium text-slate-900" href={getLocalizedPath(locale, '/contact')}>{t(locale, `${ns}.cta.button`)}</a>
          </div>
        </section>
      </div>
    )}

    {ns === 'componentsFilter' && (
      <div class="space-y-16">
        <section class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
            <div class="inline-flex rounded-2xl bg-slate-100 px-3 py-1 text-xs text-slate-700">{t(locale, `${ns}.highlight.badge`)}</div>
            <h2 class="mt-4 text-2xl font-bold text-slate-900">{t(locale, `${ns}.highlight.whyTitle`)}</h2>
            <p class="mt-4 text-slate-700">{t(locale, `${ns}.highlight.paragraph`)}</p>
          </div>
          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="aspect-[4/3]">
              <Image src="/images/components/optical-filter-closeup.jpg" alt={t(locale, `${ns}.highlight.imageAlt`)} loading="lazy" class="h-full w-full object-cover" width={1200} height={900} />
            </div>
          </div>
        </section>

        <section class="space-y-8">
          <h2 class="text-center text-3xl font-bold text-slate-900">{t(locale, `${ns}.features.title`)}</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            {[
              { title: t(locale, `${ns}.features.safety.title`), description: t(locale, `${ns}.features.safety.description`) },
              { title: t(locale, `${ns}.features.precision.title`), description: t(locale, `${ns}.features.precision.description`) },
              { title: t(locale, `${ns}.features.performance.title`), description: t(locale, `${ns}.features.performance.description`) },
              { title: t(locale, `${ns}.features.durability.title`), description: t(locale, `${ns}.features.durability.description`) },
            ].map((item) => (
              <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="text-lg font-semibold">{item.title}</div>
                <div class="mt-2 text-sm text-slate-700">{item.description}</div>
              </div>
            ))}
          </div>
        </section>

        <section class="space-y-6">
