const product = products[slug];
if (!product) {
  return new Response('Not found', { status: 404 });
}

const productGallery = product.gallery.map((image) => responsiveImageSources(image));
const heroImageSources = responsiveImageSources(product.heroImage, [400, 800, 1200], 1200);
const displayPricing = getDisplayPricing(product);
const hiddenSpecLabels = new Set(['max optical power density', 'device size', 'net weight', 'bulk moq (device)']);
const displayedSpecs = product.specs.filter((spec) => !hiddenSpecLabels.has(spec.label.trim().toLowerCase()));

const pageTitle = product.name;
const pageDescription = product.description;
const canonical = `https://iplmanufacturer.com/products/${slug}`;
const breadcrumbs = buildBreadcrumbs(locale, [
  { label: t(locale, 'common.home'), path: '/' },
  { label: t(locale, 'nav.products'), path: '/products' },
  { label: pageTitle },
]);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    item: item.href ? `https://iplmanufacturer.com${item.href}` : canonical,
  })),
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: product.gallery.map((img) => `https://iplmanufacturer.com${img}`),
  brand: {
    '@type': 'Brand',
    name: 'iShine',
  },
  offers: product.priceTiers?.length
    ? {
        '@type': 'AggregateOffer',
        priceCurrency: 'USD',
        lowPrice: product.priceTiers[product.priceTiers.length - 1]?.unitPrice,
        highPrice: product.priceTiers[0]?.unitPrice,
        offerCount: product.priceTiers.length,
        availability: 'https://schema.org/InStock',
      }
    : {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
      },
  ...(product.badge ? { award: product.badge } : {}),
};
---

<BaseLayout title={pageTitle} lang={locale} description={pageDescription} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>

  <div class="space-y-48">
    <section class="space-y-8">
      <div class="px-6 pt-6">
        <Breadcrumb items={breadcrumbs} locale={locale} />
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4" data-product-gallery>
          <div class="overflow-hidden rounded-2xl bg-slate-100">
            <picture>
              <source
                id="product-hero-image-avif"
                srcset={heroImageSources.avifSrcSet}
                sizes="(min-width: 1024px) 50vw, 100vw"
                type="image/avif"
              />
              <source
                id="product-hero-image-webp"
                srcset={heroImageSources.webpSrcSet}
                sizes="(min-width: 1024px) 50vw, 100vw"
                type="image/webp"
              />
              <img
                id="product-hero-image"
                src={heroImageSources.src}
                srcset={heroImageSources.webpSrcSet}
                sizes="(min-width: 1024px) 50vw, 100vw"
                alt={product.name}
                class="h-full w-full object-cover"
                style="aspect-ratio:1/1;max-height:500px;"
                loading="eager"
                fetchpriority="high"
                decoding="async"
                width="1200"
                height="1200"
              />
            </picture>
          </div>
          {product.gallery.length > 1 && (
            <div class="flex gap-3 overflow-x-auto pb-2">
              {productGallery.map((img, index) => (
                <button
                  type="button"
                  class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-xl bg-slate-100"
                  data-product-gallery-thumb
                  data-img={img.src}
                  data-img-srcset={img.webpSrcSet}
                  data-img-avif-srcset={img.avifSrcSet}
                  aria-label={`View ${product.name} image`}
                >
                  <picture>
                    <source srcset={img.avifSrcSet} sizes="80px" type="image/avif" />
                    <source srcset={img.webpSrcSet} sizes="80px" type="image/webp" />
                    <img
                      src={img.src}
                      srcset={img.webpSrcSet}
                      sizes="80px"
                      alt={`${product.name} gallery ${index + 1}`}
                      class="h-full w-full object-cover"
                      loading="lazy"
                      decoding="async"
                      width="160"
                      height="160"
                    />
                  </picture>
                </button>
              ))}
            </div>
          )}
          <script is:inline>
            (() => {
              const root = document.querySelector('[data-product-gallery]');
              if (!root) return;
              const hero = root.querySelector('#product-hero-image');
              const avifSource = root.querySelector('#product-hero-image-avif');
              const webpSource = root.querySelector('#product-hero-image-webp');
              if (!hero) return;

              root.addEventListener('click', (event) => {
                const target = event.target;
                if (!(target instanceof Element)) return;
                const thumb = target.closest('[data-product-gallery-thumb][data-img]');
                if (!thumb || !root.contains(thumb)) return;
                const src = thumb.getAttribute('data-img');
                const srcSet = thumb.getAttribute('data-img-srcset');
                const avifSrcSet = thumb.getAttribute('data-img-avif-srcset');
                if (!src) return;
                hero.setAttribute('src', src);
                if (srcSet) {
                  hero.setAttribute('srcset', srcSet);
                }
                if (webpSource && srcSet) {
                  webpSource.setAttribute('srcset', srcSet);
                }
                if (avifSource && avifSrcSet) {
                  avifSource.setAttribute('srcset', avifSrcSet);
                }
              });
            })();
          </script>
        </div>

        <div class="space-y-6">
          <div class="space-y-3">
            {product.badge && (
              <span class="inline-block rounded-full bg-sky-600 px-4 py-1 text-xs font-semibold uppercase tracking-wider text-white">
                {product.badge}
              </span>
            )}
            <h1 class="text-4xl font-bold text-slate-900 md:text-5xl">{product.name}</h1>
            <p class="text-xl text-sky-600 font-medium">{product.tagline}</p>
            <p class="text-base leading-relaxed text-slate-700">{product.description}</p>
            <div class="flex flex-wrap gap-2 pt-2">
              <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">OEM/ODM Ready</span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-700">Sample Support</span>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-slate-700">Factory Direct</span>
            </div>
          </div>

          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-600">Pricing & Payment</div>
                {displayPricing ? (
                  <>
                    <div class="mt-3 text-3xl font-bold tracking-tight text-slate-900">
                      USD {displayPricing.firstTier.unitPrice}
                      <span class="ml-2 text-base font-medium text-slate-500">/ unit</span>
                    </div>
                    <p class="mt-1 text-sm text-slate-600">Starting price for {displayPricing.firstTier.quantity}. Volume pricing drops to USD {displayPricing.lastTier.unitPrice} at {displayPricing.lastTier.quantity}.</p>
                  </>
                ) : (
                  <>
                    <div class="mt-3 text-2xl font-bold tracking-tight text-slate-900">Contact for quote</div>
                    <p class="mt-1 text-sm text-slate-600">{product.priceNote || 'Pricing depends on sampling scope, cosmetics, packaging, and validation requirements.'}</p>
                  </>
                )}
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3 text-sm text-slate-700">
                <div class="font-semibold text-slate-900">Commercial baseline</div>
                <div class="mt-1">Sample MOQ: 1 unit</div>
                <div>Bulk MOQ: 500 units</div>
              </div>
            </div>

            {product.priceTiers?.length ? (
              <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
                <table class="min-w-full divide-y divide-slate-200 text-sm">
                  <thead class="bg-slate-50">
                    <tr>
                      <th class="px-4 py-3 text-left font-semibold text-slate-900">Quantity</th>
                      <th class="px-4 py-3 text-right font-semibold text-slate-900">Unit Price (USD)</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-200 bg-white">
                    {product.priceTiers.map((tier, index) => (
                      <tr class={index % 2 === 0 ? 'bg-white' : 'bg-slate-50/60'}>
                        <td class="px-4 py-3 text-slate-700">{tier.quantity}</td>
                        <td class="px-4 py-3 text-right font-semibold text-slate-900">{tier.unitPrice}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : null}

            {product.priceNote ? <p class="mt-4 text-sm leading-relaxed text-slate-600">{product.priceNote}</p> : null}

            <div class="mt-6 border-t border-slate-200 pt-6">
              <h2 class="text-lg font-semibold text-slate-900">Accepted Payment Methods</h2>
              <p class="mt-2 text-sm text-slate-600">We support PayPal, bank transfer, Stripe, Alipay, and card payments for Mastercard, VISA, JCB, Discover, Diners Club, and American Express credit or debit cards.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {acceptedPayments.map((method) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-sm text-slate-700">{method}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">Specifications</h2>
            <dl class="mt-4 divide-y divide-slate-100">
              {displayedSpecs.map((spec) => (
                <div class="flex justify-between py-3 text-sm">
                  <dt class="text-slate-600">{spec.label}</dt>
                  <dd class="ml-4 text-right font-medium text-slate-900">{spec.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          {product.colors.length > 0 && (
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
              <h2 class="text-lg font-semibold text-slate-900">Available Colors</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {product.colors.map((color) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-1.5 text-sm text-slate-700">{color}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">Key Features</h2>
        <p class="mt-3 text-lg text-slate-700">What makes {product.name} the right choice for your brand.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {product.features.map((feature) => (
          <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-slate-900">{feature.title}</h3>
            <p class="mt-3 text-slate-700">{feature.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl bg-gradient-to-br from-sky-600 to-blue-700 px-8 py-14 text-center text-white">
      <h2 class="text-3xl font-bold md:text-4xl">Interested in {product.name}?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/80">Contact our team to discuss customization options, MOQ, pricing, and sample requests for your brand.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a class="rounded-lg bg-white px-8 py-3 font-semibold text-sky-700 transition hover:bg-sky-50" href={getLocalizedPath(locale, '/contact')}>Request Free Sample</a>
        <a class="rounded-lg border border-white/30 px-8 py-3 font-semibold text-white transition hover:bg-white/10" href={getLocalizedPath(locale, '/products')}>View All Products</a>
      </div>
    </section>
  </div>
</BaseLayout>
