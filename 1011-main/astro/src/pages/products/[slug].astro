  priceNote?: string;
  badge?: string;
  colors: string[];
}

function netlifyImage(path: string, width: number, format: 'avif' | 'webp', quality = 80) {
  return `/.netlify/images?url=${encodeURIComponent(path)}&w=${width}&fm=${format}&q=${quality}`;
}

function buildSrcSet(path: string, widths: number[], format: 'avif' | 'webp', quality = 80) {
  return widths.map((width) => `${netlifyImage(path, width, format, quality)} ${width}w`).join(', ');
}

function responsiveImageSources(path: string, widths = [400, 800, 1200], defaultWidth = 800) {
  return {
    path,
    src: netlifyImage(path, defaultWidth, 'webp'),
    webpSrcSet: buildSrcSet(path, widths, 'webp'),
    avifSrcSet: buildSrcSet(path, widths, 'avif'),
  };
}

const acceptedPayments = [
  'PayPal',
  'Bank Transfer',
  'Stripe',
  'Alipay',
  'Mastercard',
  'VISA',
  'JCB',
  'Discover',
  'Diners Club',
  'American Express',
];

function getDisplayPricing(product: ProductData) {
  if (!product.priceTiers?.length) {
    return null;
  }

  const firstTier = product.priceTiers[0];
  const lastTier = product.priceTiers[product.priceTiers.length - 1];

  return {
    firstTier,
    lastTier,
  };
}

