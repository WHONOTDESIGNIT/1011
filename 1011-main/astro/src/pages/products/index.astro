---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../lib/i18n';
import { getLocalizedPath } from '../../lib/breadcrumbs';
import { Image } from 'astro:assets';

const locale = 'en';
const products = [
  { slug: 'lumi', nameKey: 'nav.lumi', tagline: "RoseSkinCo's Top Selling", firstImage: '/images/products/lumi/RoseSkinCo-Lumi-IPL-Hair-Removal-Handset-white-Gold_jpg.webp' },
  { slug: 'lumi-2', nameKey: 'nav.lumi2', tagline: 'Smart Skin Sensor + Chills Skin to 10℃', firstImage: '/images/products/lumi-2/Lumi2_Gallery_Hero_1.webp' },
  { slug: 'venus', nameKey: 'nav.venus', tagline: 'Comfort Ice Feeling', firstImage: '/images/products/Venus/purple-venus-sapphire-ipl.webp' },
  { slug: 'hestia', nameKey: 'nav.hestia', tagline: 'Smart App-Connected Hair Removal', firstImage: '/images/products/Hestia/hestia-smart-app-ipl-device-12pro-2.png' },
  { slug: 'alpha', nameKey: 'nav.alpha', tagline: 'Simple and Clean IPL', firstImage: '/images/products/Alpha/alpha-ipl-device-front-view.jpg' },
  { slug: 'emerald', nameKey: 'nav.emerald', tagline: 'Be Bold--First Emerald Style IPL', firstImage: '/images/products/Emerald/emerald%20ipl%20white%20color.webp' },
  { slug: 'euno', nameKey: 'nav.euno', tagline: 'Compact & Portable Design', firstImage: '/images/products/Euno/euno%20ipl%20white%20color.webp' },
  { slug: 'themis', nameKey: 'nav.themis', tagline: 'Ice Feeling Professional Treatment', firstImage: '/images/products/Themis/golden-luxury-front-view.jpg' },
  { slug: 'hebe', nameKey: 'nav.hebe', tagline: 'AI-Powered Skin Detection', firstImage: '/images/products/Hebe/hebe%20ipl%20hair%20removal%20white%20color.webp' },
  { slug: 'eirene', nameKey: 'nav.eirene', tagline: 'Battery-build-in IPL, Cordless IPL', firstImage: '/images/products/Eirene/battery-built-in%20ipl%20device%20front%20view.jpg' },
  { slug: 'wooden', nameKey: 'nav.wooden', tagline: 'Natural design, inspired by Whynotdesign.', firstImage: '/images/products/Wooden/wooden%20ipl%20white%20color%20front%20view.webp' },
];

const platformTracks = [
  {
    title: 'Comfort-first cooling',
    description: 'Best for brands selling “painless” positioning and sensitive-area comfort.',
    links: [
      { label: 'Venus (Cooling)', href: getLocalizedPath(locale, '/products/venus') },
      { label: 'Lumi 2 (Cooling to 10°C)', href: getLocalizedPath(locale, '/products/lumi-2') },
    ],
  },
  {
    title: 'Smart app-guided routines',
    description: 'Best for retention-driven brands that use app workflows and scheduling.',
    links: [
      { label: 'Hestia (App tracking)', href: getLocalizedPath(locale, '/products/hestia') },
      { label: 'Lumi (Smart app control)', href: getLocalizedPath(locale, '/products/lumi') },
    ],
  },
  {
    title: 'Portable / travel',
    description: 'Best for compact positioning and lightweight bundles.',
    links: [{ label: 'Euno (Portable)', href: getLocalizedPath(locale, '/products/euno') }],
  },
  {
    title: 'Luxury unboxing',
    description: 'Best for premium packaging and giftable positioning.',
    links: [{ label: 'Golden (Wooden luxury)', href: getLocalizedPath(locale, '/products/wooden') }],
  },
  {
    title: 'Professional performance',
    description: 'Best for high-output positioning and faster full-body routines.',
    links: [
      { label: 'Themis (Salon-grade)', href: getLocalizedPath(locale, '/products/themis') },
      { label: 'Alpha (Dual-lamp efficiency)', href: getLocalizedPath(locale, '/products/alpha') },
    ],
  },
];

const productFaq = [
  {
    question: 'How do we choose the right IPL platform for our brand?',
    answer:
      'Start with positioning and channel: comfort-first cooling, app-guided routines, portability, luxury unboxing, or professional performance. Then validate key specs and customization scope in sampling.',
    links: [{ label: 'Compare models in the Catalogue', href: getLocalizedPath(locale, '/catalogue') }],
  },
  {
    question: 'What can be customized in a private-label IPL program?',
    answer:
      'Typical customization includes device cosmetics and colors, logo placement, packaging and inserts, user manuals and quick-start guides, labeling, and bundle accessories. Logistics and dropshipping workflows can be configured by channel.',
    links: [
      { label: 'Logo Printing', href: getLocalizedPath(locale, '/services/logo-printing') },
      { label: 'Box Customization', href: getLocalizedPath(locale, '/services/box-custom') },
      { label: 'User Manual Customization', href: getLocalizedPath(locale, '/services/user-manual-guide-custom') },
    ],
  },
  {
    question: 'Can we start with a pilot order?',
    answer:
      'Yes. Many programs can start with a smaller pilot order to validate demand and positioning before scaling with predictable replenishment.',
    links: [{ label: 'Start with No MOQ', href: getLocalizedPath(locale, '/services/no-moq') }],
  },
  {
    question: 'Do you support dropshipping and export logistics?',
    answer:
      'Yes. We support packaging, labeling, export documents, shipping coordination, and dropshipping workflows depending on your channel and destination.',
    links: [
      { label: 'Packaging & Logistics', href: getLocalizedPath(locale, '/services/packaging-logistics') },
      { label: 'Dropshipping', href: getLocalizedPath(locale, '/services/dropshipping') },
    ],
  },
];
---

<BaseLayout
  title="IPL Device Platforms for Private Label | iShine"
  lang={locale}
  description="Explore iShine IPL device platforms for private label and OEM/ODM: cooling-focused models, app-connected routines, portable devices, luxury cosmetics, and professional-performance platforms."
>
  <div class="space-y-36">
    <section class="relative w-screen left-1/2 -translate-x-1/2 overflow-hidden -mt-[160px] pt-[160px] min-h-[400px] md:min-h-[500px] lg:min-h-[600px]">
      <Image
        src="/images/products/ipl-products-banner.webp"
        alt="IPL Products"
        loading="eager"
        class="absolute inset-0 h-full w-full object-cover"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 bg-black/20" />
      <div class="relative z-10 flex h-full items-end px-6 pb-10 md:px-12">
        <div class="max-w-4xl">
          <h1 class="text-4xl font-bold tracking-tight text-white md:text-5xl lg:text-6xl">IPL Device Platforms</h1>
          <p class="mt-4 max-w-3xl text-lg text-white/90">
            Choose a platform that matches your positioning—cooling comfort, smart routines, portability, luxury cosmetics, or professional performance—then customize branding, packaging, and fulfillment.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100" href={getLocalizedPath(locale, '/catalogue')}>
              Compare Models
            </a>
            <a class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/15" href={getLocalizedPath(locale, '/services')}>
              Explore Services
            </a>
            <a class="rounded-2xl border border-white/30 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/15" href={getLocalizedPath(locale, '/contact')}>
              Get a Quote
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What product types does iShine offer for private-label IPL?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        iShine offers a portfolio of home-use IPL device platforms that can be adapted for private-label launches across different price tiers and channel positioning. Product families commonly include app-connected models for guided routines and progress tracking, cooling-focused models with sapphire contact cooling for comfort, AI-enabled skin sensing configurations for safer energy selection, and premium cosmetics built for DTC or retail unboxing. Typical specification targets vary by platform, such as energy ranges around 5-9 J/cm², flash counts near 999,000 (or 500,000 on compact models), treatment windows around 4.5 cm² (with larger windows available on select platforms), and wavelength bands like 550-1200 nm or 570-1200 nm in supported configurations. Brands can customize cosmetics, colors, packaging, manuals, labeling, accessories, and bundle configuration to match channel requirements while keeping manufacturing repeatability. This catalog is used as a starting point for OEM/ODM discussions about sampling, MOQ, compliance documentation, and scale delivery.
      </p>
    </section>

    <section class="space-y-10">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">How to Choose</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Pick a track, then open platform pages</h2>
        <p class="mt-4 text-lg text-slate-700">Use the links below to jump straight to the most relevant platforms.</p>
      </div>
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-2 lg:grid-cols-3">
        {platformTracks.map((track) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm">
            <h3 class="text-2xl font-semibold tracking-tight text-slate-900">{track.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">{track.description}</p>
            <ul class="mt-6 space-y-3 text-sm font-semibold text-slate-900">
              {track.links.map((link) => (
                <li>
                  <a class="inline-flex items-center gap-2 text-slate-900 transition hover:text-violet-700" href={link.href}>
                    <span class="h-2.5 w-2.5 rounded-2xl bg-violet-500" />
                    <span>{link.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <a
          class="product-card flex flex-col overflow-hidden rounded-xl border-2 border-black bg-white shadow-sm transition-all hover:shadow-md"
          href={getLocalizedPath(locale, '/products/' + product.slug)}
        >
          <div class="relative bg-slate-100" style="aspect-ratio:1000/806">
            <img
              class="h-full w-full object-cover"
              src={product.firstImage}
              alt={t(locale, product.nameKey)}
              loading="lazy"
            />
          </div>
          <div class="flex flex-col justify-end p-3" style="aspect-ratio:1000/194">
            <div>
              <h2 class="text-xl font-semibold text-slate-900">{t(locale, product.nameKey)}</h2>
              <p class="mt-1 text-sm text-slate-700">{product.tagline}</p>
            </div>
          </div>
        </a>
      ))}
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <div class="grid gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:grid-cols-3 md:p-10">
        <div class="md:col-span-2">
          <div class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">Next Step</div>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">Turn a platform into a brand-ready product</h2>
          <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
            After you shortlist a platform, we help you customize branding, packaging, manuals, and fulfillment so the final product matches your channel and positioning.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="rounded-2xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={getLocalizedPath(locale, '/services/no-moq')}>
              Start with No MOQ
            </a>
            <a class="rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50" href={getLocalizedPath(locale, '/services/box-custom')}>
              Customize Your Box & Inserts
            </a>
            <a class="rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50" href={getLocalizedPath(locale, '/services/dropshipping')}>
              Ship Directly to Customers
            </a>
          </div>
        </div>
        <div class="rounded-2xl bg-slate-50 p-6">
          <div class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Fast Links</div>
          <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-900">
            <li><a class="transition hover:text-violet-700" href={getLocalizedPath(locale, '/services/logo-printing')}>Add Logo Printing</a></li>
            <li><a class="transition hover:text-violet-700" href={getLocalizedPath(locale, '/services/user-manual-guide-custom')}>User Manual Customization</a></li>
            <li><a class="transition hover:text-violet-700" href={getLocalizedPath(locale, '/services/packaging-logistics')}>Packaging & Export Logistics</a></li>
            <li><a class="transition hover:text-violet-700" href={getLocalizedPath(locale, '/contact')}>Get a Quote</a></li>
          </ul>
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">FAQ</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Questions brands ask before choosing a platform</h2>
        <p class="mt-4 text-lg text-slate-700">Short answers with direct links to the relevant pages.</p>
      </div>
      <div class="mx-auto grid max-w-4xl gap-4">
        {productFaq.map((item) => (
          <details class="group rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              <div class="flex items-start justify-between gap-4">
                <span>{item.question}</span>
                <span class="mt-1 text-slate-500 transition group-open:rotate-45">+</span>
              </div>
            </summary>
            <div class="mt-4 space-y-4 text-sm leading-relaxed text-slate-700">
              <p>{item.answer}</p>
              <div class="flex flex-wrap gap-3">
                {item.links.map((link) => (
                  <a class="inline-flex items-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:border-slate-300 hover:bg-slate-50" href={link.href}>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <div
        class="w-full overflow-hidden rounded-2xl bg-slate-100"
        style="background-image:url('/images/products/free_sample.jpg');background-size:contain;background-repeat:no-repeat;background-position:center;min-height:520px;"
      />
    </section>
  </div>
</BaseLayout>
