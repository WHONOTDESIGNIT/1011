---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../lib/breadcrumbs';

const locale = 'en';
const capabilities = [
  {
    title: 'Order handling',
    description: 'Turn daily orders into consistent dispatch with clear SOPs.',
    items: ['Bulk order import', 'Daily pick/pack routines', 'Exception handling process', 'Cutoff time alignment'],
  },
  {
    title: 'Packaging options',
    description: 'Match your brand and channel requirements without slowing fulfillment.',
    items: ['Neutral packaging', 'Branded inserts', 'Channel labels and barcodes', 'Accessory kitting'],
  },
  {
    title: 'Tracking and support',
    description: 'Give customers visibility and reduce support tickets.',
    items: ['Tracking number sync', 'Status updates', 'Delivery issue escalation', 'Returns workflow support'],
  },
];
---

<BaseLayout title="Dropshipping Support | iShine" lang={locale} description="Dropshipping support for IPL private-label brands: order handling, packaging options, tracking sync, and exceptions/returns workflows.">
  <div class="space-y-60">
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-50 via-white to-sky-50 px-8 py-12 shadow-sm md:px-10 lg:px-12 lg:py-16">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(168,85,247,0.10),_transparent_28%),radial-gradient(circle_at_bottom_left,_rgba(56,189,248,0.14),_transparent_30%)]" />
      <div class="relative mx-auto max-w-5xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          Dropshipping
          <span class="block bg-gradient-to-r from-violet-600 to-sky-600 bg-clip-text text-transparent">Without Chaos</span>
        </h1>
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-slate-700">
          Ship directly to your customers with a reliable workflow: predictable dispatch, clean packaging rules, and tracking visibility that reduces support friction.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a class="rounded-2xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={getLocalizedPath(locale, '/contact')}>
            Set Up Dropshipping
          </a>
          <a class="rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50" href={getLocalizedPath(locale, '/services')}>
            Back to Services
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What does dropshipping support include for an IPL brand?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        Dropshipping support for an IPL brand typically includes order intake and daily dispatch processes, packaging rules (neutral or branded inserts), labeling and kitting, and tracking number synchronization. A complete workflow also defines exception handling and returns support so delivery issues do not overwhelm customer service. The goal is consistent fulfillment quality that protects the brand experience while keeping operational overhead manageable.
      </p>
    </section>

    <section class="space-y-10">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">Capabilities</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">Dropshipping capabilities</h2>
        <p class="mt-4 text-lg text-slate-700">A practical setup that scales as your daily order volume grows.</p>
      </div>
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3">
        {capabilities.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm">
            <h3 class="text-xl font-semibold tracking-tight text-slate-900">{card.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">{card.description}</p>
            <ul class="mt-6 space-y-3 text-sm text-slate-700">
              {card.items.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-2xl bg-violet-500" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
