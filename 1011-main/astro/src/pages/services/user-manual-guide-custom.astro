---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLocalizedPath } from '../../lib/breadcrumbs';

const locale = 'en';
const manualModules = [
  {
    title: 'Quick-start guide',
    description: 'Make first-use frictionless with a simple, visual flow.',
    features: ['Setup checklist', 'Skin tone and safety steps', 'Treatment cadence chart', 'Care and cleaning basics'],
  },
  {
    title: 'Safety and compliance content',
    description: 'Clear warnings reduce misuse and support post-purchase trust.',
    features: ['Contraindications and risk notes', 'Eye safety guidance', 'Device handling and storage', 'Labeling alignment support'],
  },
  {
    title: 'Localization and support',
    description: 'Support your target markets with language-ready content and faster troubleshooting.',
    features: ['Translation and proofreading', 'Region-specific contact details', 'QR codes to tutorials', 'FAQ formatting for support teams'],
  },
];
---

<BaseLayout title="User Manual & Guide Customization | iShine" lang={locale} description="User manual and guide customization for IPL private-label programs: quick-start guides, safety content, localization, and QR-linked support materials.">
  <div class="space-y-60">
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-slate-50 via-white to-violet-50 px-8 py-12 shadow-sm md:px-10 lg:px-12 lg:py-16">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(168,85,247,0.12),_transparent_25%),radial-gradient(circle_at_bottom_left,_rgba(15,23,42,0.12),_transparent_32%)]" />
      <div class="relative mx-auto max-w-5xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          Manuals That
          <span class="block bg-gradient-to-r from-violet-700 to-slate-900 bg-clip-text text-transparent">Reduce Returns</span>
        </h1>
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-slate-700">
          A good manual is part of the product. We customize guides that make users succeed on session one, explain safety clearly, and reduce customer support load.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a class="rounded-2xl bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" href={getLocalizedPath(locale, '/contact')}>
            Request Manual Customization
          </a>
          <a class="rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-slate-50" href={getLocalizedPath(locale, '/services')}>
            Back to Services
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-600">Citable Summary</h2>
      <h3 class="mt-2 text-2xl font-bold tracking-tight text-slate-900">What is included in user manual and guide customization?</h3>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-slate-700">
        User manual and guide customization typically includes a quick-start guide, detailed usage instructions, safety warnings, and localized content for target markets. A complete program also adds diagrams, treatment cadence charts, troubleshooting sections, and QR codes linking to video tutorials or FAQs. The goal is clearer first-use success, fewer misuse incidents, and reduced return and support rates.
      </p>
    </section>

    <section class="space-y-10">
      <div class="mx-auto max-w-3xl text-center">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">Modules</div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">What we can customize</h2>
        <p class="mt-4 text-lg text-slate-700">Choose what you need for your channel, language, and brand positioning.</p>
      </div>
      <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3">
        {manualModules.map((card) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-sm">
            <h3 class="text-xl font-semibold tracking-tight text-slate-900">{card.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-700">{card.description}</p>
            <ul class="mt-6 space-y-3 text-sm text-slate-700">
              {card.features.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 h-2.5 w-2.5 flex-shrink-0 rounded-2xl bg-violet-500" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
